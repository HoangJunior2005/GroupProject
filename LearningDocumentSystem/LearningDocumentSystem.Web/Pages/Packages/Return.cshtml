@page
@model LearningDocumentSystem.Web.Pages.Packages.ReturnModel
@{
    ViewData["Title"] = "Ket qua thanh toan";
}

<div class="mx-auto" style="max-width:620px;">
    <div class="bg-white border p-4 text-center" style="border-radius:8px;">
        @if (Model.Result.IsValid && Model.Result.IsSuccess)
        {
            <i class="bi bi-check-circle-fill text-success" style="font-size:3rem;"></i>
            <h1 class="h4 mt-3">Thanh toan thanh cong</h1>
            <p class="text-muted">Goi <strong>@Model.Result.PlanCode</strong> da duoc kich hoat cho tai khoan cua ban.</p>
        }
        else
        {
            <i class="bi bi-x-circle-fill text-danger" style="font-size:3rem;"></i>
            <h1 class="h4 mt-3">Thanh toan chua hoan tat</h1>
            <p class="text-muted">@Model.Result.Message</p>
        }
        <div class="small text-muted mb-3">Ma giao dich: @Model.Result.TransactionReference</div>
        <a asp-page="/Packages/Index" class="btn btn-primary">Quay lai cac goi</a>
    </div>
</div>
