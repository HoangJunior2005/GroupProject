@page
@model LearningDocumentSystem.Web.Pages.Chat.IndexModel
@using LearningDocumentSystem.Business.DTOs
@using System.Text.Json
@{
    ViewData["Title"] = "Hỏi đáp AI";
    var subjects = Model.Subjects ?? Enumerable.Empty<SubjectDto>();
    var allowedProviders = JsonSerializer.Serialize(Model.PackageStatus.AllowedProviders);
}

<!-- Custom Styles for Premium Chat Interface -->
<style>
    /* ─── Layout ────────────────────────────────────────────────── */
    .chat-container {
        height: 80vh;
        display: flex;
        gap: 16px;
    }

    /* ─── Left Sidebar ──────────────────────────────────────────── */
    .chat-sidebar {
        width: 300px;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        gap: 14px;
        overflow: hidden;
    }

    /* ─── Session Panel ─────────────────────────────────────────── */
    .session-panel {
        display: flex;
        flex-direction: column;
        flex: 1;
        min-height: 0;
        background: rgba(255,255,255,0.75);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.3);
        border-radius: 14px;
        box-shadow: 0 4px 20px rgba(31,38,135,0.07);
        overflow: hidden;
    }

    .session-panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 14px;
        background: linear-gradient(135deg, #4f46e5 0%, #3b82f6 100%);
        color: white;
        flex-shrink: 0;
    }

    .session-panel-header h6 {
        margin: 0;
        font-weight: 700;
        font-size: 0.88rem;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .btn-new-session {
        border: 1px solid rgba(255,255,255,0.5);
        background: rgba(255,255,255,0.15);
        color: white;
        border-radius: 8px;
        padding: 4px 10px;
        font-size: 0.78rem;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 4px;
        transition: all 0.2s;
    }

    .btn-new-session:hover {
        background: rgba(255,255,255,0.3);
        border-color: white;
    }

    .session-list {
        flex: 1;
        overflow-y: auto;
        padding: 8px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .session-list::-webkit-scrollbar { width: 4px; }
    .session-list::-webkit-scrollbar-track { background: transparent; }
    .session-list::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 2px; }

    .session-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 9px 10px;
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.18s;
        border: 1px solid transparent;
        position: relative;
    }

    .session-item:hover {
        background: #f1f5f9;
        border-color: #e2e8f0;
    }

    .session-item.active {
        background: linear-gradient(135deg, rgba(79,70,229,0.08) 0%, rgba(59,130,246,0.08) 100%);
        border-color: rgba(79,70,229,0.3);
    }

    .session-item-icon {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: linear-gradient(135deg, #4f46e5 0%, #3b82f6 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 0.75rem;
        flex-shrink: 0;
    }

    .session-item.active .session-item-icon {
        box-shadow: 0 2px 8px rgba(79,70,229,0.4);
    }

    .session-item-body {
        flex: 1;
        min-width: 0;
    }

    .session-item-title {
        font-size: 0.82rem;
        font-weight: 600;
        color: #1e293b;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.3;
    }

    .session-item.active .session-item-title { color: #4f46e5; }

    .session-item-date {
        font-size: 0.7rem;
        color: #94a3b8;
        margin-top: 2px;
    }

    .session-item-preview {
        font-size: 0.75rem;
        color: #64748b;
        margin-top: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .session-item.active .session-item-preview {
        color: #4f46e5;
        opacity: 0.85;
    }

    .btn-delete-session {
        width: 22px;
        height: 22px;
        border: none;
        background: transparent;
        color: #94a3b8;
        border-radius: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        opacity: 0;
        cursor: pointer;
        transition: all 0.15s;
        font-size: 0.75rem;
    }

    .session-item:hover .btn-delete-session { opacity: 1; }
    .btn-delete-session:hover { background: #fee2e2; color: #ef4444; }

    .session-empty {
        text-align: center;
        padding: 24px 12px;
        color: #94a3b8;
        font-size: 0.82rem;
    }

    /* ─── Filter Card ────────────────────────────────────────────── */
    .filter-card {
        background: rgba(255,255,255,0.75);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.3);
        border-radius: 14px;
        box-shadow: 0 4px 20px rgba(31,38,135,0.07);
        padding: 14px;
        flex-shrink: 0;
    }

    .filter-card-title {
        font-size: 0.82rem;
        font-weight: 700;
        color: #475569;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    /* ─── Main Chat Area ─────────────────────────────────────────── */
    .chat-main {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 16px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.08);
        overflow: hidden;
        position: relative;
    }

    .chat-header {
        padding: 14px 24px;
        background: linear-gradient(135deg, #4f46e5 0%, #3b82f6 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        flex-shrink: 0;
    }

    .chat-header-title h5 {
        margin: 0;
        font-weight: 700;
        letter-spacing: -0.5px;
        font-size: 1rem;
    }

    .chat-header-title .session-title-badge {
        font-size: 0.72rem;
        font-weight: 500;
        opacity: 0.8;
        margin-top: 1px;
    }

    .chat-header-status {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.8rem;
        background: rgba(255, 255, 255, 0.15);
        padding: 4px 12px;
        border-radius: 20px;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        background-color: #10b981;
        border-radius: 50%;
        display: inline-block;
        box-shadow: 0 0 8px #10b981;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
    }

    .chat-messages {
        flex-grow: 1;
        padding: 24px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 20px;
        scroll-behavior: smooth;
    }

    .message {
        display: flex;
        gap: 12px;
        max-width: 80%;
        animation: fadeIn 0.3s ease;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .message.user {
        align-self: flex-end;
        flex-direction: row-reverse;
    }

    .message.assistant {
        align-self: flex-start;
    }

    .message-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        flex-shrink: 0;
        font-size: 0.8rem;
    }

    .message.user .message-avatar {
        background: #4f46e5;
        color: white;
    }

    .message.assistant .message-avatar {
        background: #e2e8f0;
        color: #4f46e5;
        border: 1px solid rgba(0,0,0,0.05);
    }

    .message-content {
        padding: 12px 18px;
        border-radius: 14px;
        font-size: 0.95rem;
        line-height: 1.5;
        position: relative;
    }

    .message.user .message-content {
        background: #4f46e5;
        color: white;
        border-top-right-radius: 2px;
    }

    .message.assistant .message-content {
        background: white;
        color: #1e293b;
        border-top-left-radius: 2px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        border: 1px solid rgba(0,0,0,0.05);
    }

    .message-sources {
        margin-top: 10px;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        font-size: 0.8rem;
    }

    .source-tag {
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #475569;
        padding: 4px 10px;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .source-tag:hover {
        background: #e2e8f0;
        color: #1e293b;
        transform: translateY(-1px);
    }

    .source-score {
        background: #3b82f6;
        color: white;
        font-weight: 700;
        padding: 1px 4px;
        border-radius: 4px;
        font-size: 0.7rem;
    }

    .chat-input-area {
        padding: 14px 24px;
        background: white;
        border-top: 1px solid rgba(0,0,0,0.05);
        flex-shrink: 0;
    }

    .chat-input-wrapper {
        display: flex;
        gap: 12px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        padding: 4px 6px 4px 16px;
        align-items: center;
        transition: all 0.3s;
    }

    .chat-input-wrapper:focus-within {
        border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
        background: white;
    }

    .chat-input {
        flex-grow: 1;
        border: none;
        background: transparent;
        padding: 8px 0;
        font-size: 0.95rem;
        color: #1e293b;
        outline: none;
    }

    .btn-send {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #4f46e5;
        color: white;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-send:hover { background: #3730a3; transform: scale(1.05); }
    .btn-send:disabled { background: #cbd5e1; cursor: not-allowed; transform: none; }

    /* Loading dots */
    .thinking { display: flex; gap: 4px; padding: 8px 10px; align-items: center; }
    .dot { width: 8px; height: 8px; background: #94a3b8; border-radius: 50%; animation: bounce 1.4s infinite ease-in-out both; }
    .dot:nth-child(1) { animation-delay: -0.32s; }
    .dot:nth-child(2) { animation-delay: -0.16s; }

    @@keyframes bounce {
        0%, 80%, 100% { transform: scale(0); }
        40% { transform: scale(1); }
    }

    /* Markdown */
    .message-content p { margin-bottom: 8px; }
    .message-content p:last-child { margin-bottom: 0; }
    .message-content code { background: rgba(0,0,0,0.05); padding: 2px 4px; border-radius: 4px; font-family: monospace; font-size: 0.9em; }
    .message-content ul, .message-content ol { margin-bottom: 8px; padding-left: 20px; }
    .hover-white:hover { color: #ffffff !important; }

    /* Lock overlay */
    .chat-lock-overlay {
        position: absolute;
        inset: 0;
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 16px;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(6px);
        border-radius: 16px;
        transition: opacity 0.35s ease, visibility 0.35s ease;
        opacity: 1;
        visibility: visible;
    }
    .chat-lock-overlay.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
    .chat-lock-icon {
        width: 68px; height: 68px; border-radius: 50%;
        background: linear-gradient(135deg, #4f46e5 0%, #3b82f6 100%);
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 8px 24px rgba(79,70,229,0.35);
        animation: lockPulse 2.5s ease-in-out infinite;
    }
    @@keyframes lockPulse {
        0%, 100% { box-shadow: 0 8px 24px rgba(79,70,229,0.35); transform: scale(1); }
        50% { box-shadow: 0 8px 36px rgba(79,70,229,0.55); transform: scale(1.06); }
    }
    .chat-lock-icon i { font-size: 1.8rem; color: white; }
    .chat-lock-text { text-align: center; max-width: 280px; }
    .chat-lock-text h6 { font-weight: 700; color: #1e293b; margin-bottom: 6px; font-size: 1rem; }
    .chat-lock-text p { color: #64748b; font-size: 0.875rem; margin: 0; line-height: 1.5; }

    /* Session saving indicator */
    .save-indicator {
        font-size: 0.7rem;
        color: #94a3b8;
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 6px 24px;
        background: white;
    }

    /* Antigravity IDE Style Model Selector */
    .model-dropdown-container {
        position: relative;
        display: inline-block;
    }
    .model-dropdown-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 14px;
        background: #eef2ff;
        color: #312e81;
        border: 1.5px solid #818cf8;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 2px 4px rgba(99, 102, 241, 0.1);
    }
    .model-dropdown-btn:hover {
        background: #e0e7ff;
        border-color: #6366f1;
        color: #1e1b4b;
        box-shadow: 0 4px 8px rgba(99, 102, 241, 0.18);
    }
    .model-dropdown-menu {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        z-index: 1000;
        width: 320px;
        background: #ffffff;
        border: 1px solid #cbd5e1;
        border-radius: 14px;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.15);
        padding: 6px 0;
        color: #1e293b;
        font-family: inherit;
        animation: dropFadeIn 0.15s ease-out;
    }
    .model-dropdown-menu.hidden {
        display: none !important;
    }
    @@keyframes dropFadeIn {
        from { opacity: 0; transform: translateY(-6px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .model-dropdown-header {
        font-size: 0.72rem;
        font-weight: 700;
        color: #64748b;
        padding: 6px 14px 6px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .model-option {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 14px;
        margin: 2px 6px;
        border-radius: 10px;
        cursor: pointer;
        border: 1px solid transparent;
        transition: all 0.15s ease;
    }
    .model-option:hover {
        background: #f1f5f9;
    }
    .model-option.active {
        border: 1px solid #6366f1;
        background: #eef2ff;
    }
    .model-option-left {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    .model-option-title {
        font-size: 0.88rem;
        font-weight: 600;
        color: #1e293b;
        display: flex;
        align-items: center;
    }
    .model-option.active .model-option-title {
        color: #312e81;
    }
    .model-option-sub {
        font-size: 0.7rem;
        color: #64748b;
    }
    .model-option-badge {
        background: #f8fafc;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 2px 8px;
        font-size: 0.7rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        flex-shrink: 0;
    }
    .model-option.active .model-option-badge {
        background: #6366f1;
        border-color: #4f46e5;
        color: #ffffff;
    }
</style>

<div class="page-header mb-3">
    <div>
        <h1 class="page-title"><i class="bi bi-robot me-2"></i>Hỏi đáp AI</h1>
        <p class="page-subtitle">Hỏi đáp thông minh dựa trên tài liệu học tập của bạn</p>
    </div>
</div>

<div class="chat-container">

    <!-- ═══ LEFT SIDEBAR ═══ -->
    <div class="chat-sidebar">

        <!-- Phiên hội thoại Panel -->
        <div class="session-panel">
            <div class="session-panel-header">
                <h6><i class="bi bi-clock-history"></i> Lịch sử phiên</h6>
                <button class="btn-new-session" id="btnNewSession" onclick="createNewSession()">
                    <i class="bi bi-plus-lg"></i> Phiên mới
                </button>
            </div>
            <div class="session-list" id="sessionList">
                <div class="session-empty" id="sessionEmpty">
                    <i class="bi bi-chat-dots mb-2 d-block fs-4 opacity-50"></i>
                    Chưa có phiên hội thoại nào.<br>Nhấn <strong>"Phiên mới"</strong> để bắt đầu.
                </div>
            </div>
        </div>

        <!-- Bộ lọc tài liệu -->
        <div class="filter-card">
            <div class="filter-card-title"><i class="bi bi-sliders"></i> Phạm vi tài liệu</div>
            <div class="mb-2">
                <label class="form-label small fw-semibold" style="font-size:0.8rem;">Môn học</label>
                <select class="form-select form-select-sm" id="chatSubjectSelect" onchange="onSubjectChanged(this.value)">
                    <option value="">— Tất cả môn học —</option>
                    @foreach (var s in subjects)
                    {
                        <option value="@s.SubjectID">[@s.SubjectCode] @s.SubjectName</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label small fw-semibold" style="font-size:0.8rem;">Chương học</label>
                <select class="form-select form-select-sm" id="chatChapterSelect" disabled>
                    <option value="">— Tất cả chương —</option>
                </select>
            </div>
            <button type="button" class="btn btn-outline-secondary btn-sm w-100" onclick="resetChatFilters()">
                <i class="bi bi-arrow-counterclockwise me-1"></i>Xóa bộ lọc
            </button>
        </div>

    </div>

    <!-- ═══ MAIN CHATBOX ═══ -->
    <div class="chat-main">

        <!-- Lock overlay -->
        <div class="chat-lock-overlay" id="chatLockOverlay">
            <div class="chat-lock-icon"><i class="bi bi-chat-square-dots-fill"></i></div>
            <div class="chat-lock-text">
                <h6>Chọn hoặc tạo phiên hội thoại</h6>
                <p>Nhấn <strong>"Phiên mới"</strong> ở cột trái để bắt đầu cuộc hội thoại mới, hoặc chọn phiên cũ để xem lại.</p>
            </div>
        </div>

        <!-- Header -->
        <div class="chat-header">
            <div class="chat-header-title">
                <h5>LDS AI Assistant</h5>
                <div class="session-title-badge" id="activeSessionTitle">Chưa chọn phiên</div>
            </div>
            <div class="chat-header-status d-none d-lg-flex">
                <span class="status-dot"></span>
                <span>AI Engine Sẵn sàng</span>
            </div>
        </div>

        <!-- Model Selector Sub-header (Antigravity IDE Style) -->
        <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;padding:8px 24px;background:#ecfdf5;border-bottom:1px solid #a7f3d0;font-size:.82rem;">
            <span><strong>G&#243;i @Model.PackageStatus.CurrentPlan</strong> &middot;
                @if (Model.PackageStatus.DailyMessageLimit.HasValue)
                {
                    <span>C&#242;n @Model.PackageStatus.RemainingToday / @Model.PackageStatus.DailyMessageLimit c&#226;u h&#244;m nay</span>
                }
                else
                {
                    <span>Kh&#244;ng gi&#7899;i h&#7841;n c&#226;u h&#7887;i</span>
                }
            </span>
            <a asp-page="/Packages/Index" class="text-decoration-none fw-semibold">Qu&#7843;n l&#253; g&#243;i</a>
        </div>

        <div class="model-selector-bar" style="display:flex; align-items:center; justify-content:space-between; padding:10px 24px; background: #f8fafc; border-bottom:1px solid #e2e8f0; position: relative; z-index: 50;">
            <div class="d-flex align-items-center gap-2">
                <span style="font-size: 0.82rem; color: #64748b; font-weight: 600;"><i class="bi bi-cpu me-1"></i>AI Model:</span>
                
                <!-- Dropdown Button -->
                <div class="model-dropdown-container" style="position: relative;">
                    <button type="button" class="model-dropdown-btn" id="btnModelSelect" onclick="toggleModelDropdown(event)">
                        <span id="selectedModelIcon">✨</span>
                        <span id="selectedModelName">Gemini 2.5 Flash</span>
                        <i class="bi bi-chevron-down ms-1" style="font-size: 0.75rem; opacity: 0.7;"></i>
                    </button>
                    
                    <!-- Dropdown Popover Menu -->
                    <div class="model-dropdown-menu hidden" id="modelDropdownMenu">
                        <div class="model-dropdown-header">Model</div>
                        <div class="model-option active" data-provider="Gemini" data-name="Gemini 2.5 Flash" data-icon="✨" onclick="selectModelProvider(this)">
                            <div class="model-option-left">
                                <div class="model-option-title"><span class="me-1">✨</span>Gemini 2.5 Flash</div>
                                <div class="model-option-sub">High Quality • Fast</div>
                            </div>
                            <div class="model-option-badge">Fast <i class="bi bi-info-circle"></i></div>
                        </div>
                        <div class="model-option" data-provider="OpenAI" data-name="OpenAI GPT OSS" data-icon="🤖" onclick="selectModelProvider(this)">
                            <div class="model-option-left">
                                <div class="model-option-title"><span class="me-1">🤖</span>OpenAI GPT OSS</div>
                                <div class="model-option-sub">Open-Weight 120B • Cerebras Fast Engine</div>
                            </div>
                            <div class="model-option-badge">Ultra <i class="bi bi-info-circle"></i></div>
                        </div>
                        <div class="model-option" data-provider="Groq" data-name="Llama 3.1 8B" data-icon="⚡" onclick="selectModelProvider(this)">
                            <div class="model-option-left">
                                <div class="model-option-title"><span class="me-1">⚡</span>Llama 3.1 8B</div>
                                <div class="model-option-sub">Ultra Fast • Open Source</div>
                            </div>
                            <div class="model-option-badge">Ultra <i class="bi bi-info-circle"></i></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-muted small d-none d-md-block" style="font-size: 0.78rem;">
                <i class="bi bi-shield-check text-success me-1"></i>Chế độ RAG: Chỉ trả lời trong phạm vi tài liệu bài giảng
            </div>
            <!-- Hidden input to hold selected value -->
            <input type="hidden" id="modelProviderSelect" value="Gemini">
        </div>

        <!-- Messages -->
        <div class="chat-messages" id="chatMessages">
            <div class="message assistant" id="welcomeMessage">
                <div class="message-avatar">AI</div>
                <div class="message-content">
                    <p>Chào bạn! Tôi là <strong>LDS AI Assistant</strong>.</p>
                    <p>Chọn một phiên hội thoại ở cột trái hoặc tạo phiên mới để bắt đầu. Tôi sẽ trả lời dựa trên các tài liệu học tập đã được tải lên.</p>
                </div>
            </div>
        </div>

        <!-- Save indicator -->
        <div class="save-indicator" id="saveIndicator" style="display:none;">
            <i class="bi bi-cloud-check text-success"></i> Đã lưu vào phiên hội thoại
        </div>

        <!-- Input -->
        <div class="chat-input-area">
            <form id="chatForm" onsubmit="sendChatMessage(event)">
                @Html.AntiForgeryToken()
                <div class="chat-input-wrapper">
                    <input type="text" class="chat-input" id="chatInput"
                           placeholder="Chọn hoặc tạo phiên hội thoại trước..." autocomplete="off" disabled />
                    <button type="submit" class="btn-send" id="btnSend" disabled>
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </form>
        </div>

    </div>
</div>

<!-- Source Detail Modal -->
<div class="modal fade" id="sourceModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header border-0 bg-light">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-file-earmark-text-fill text-primary me-2"></i>Chi tiết đoạn trích dẫn</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="badge bg-primary fs-6" id="sourceDocTitle">Tài liệu</span>
                    <span class="badge bg-success" id="sourceScore">99% Match</span>
                </div>
                <div class="mb-3 small text-muted">
                    <i class="bi bi-file-text me-1"></i>Vị trí trích xuất: <strong id="sourcePage">Trang 1</strong>
                </div>
                <div class="p-3 bg-light border rounded text-dark"
                     style="font-family: Inter, sans-serif; font-size: 0.95rem; line-height: 1.6; max-height: 40vh; overflow-y: auto; white-space: pre-wrap;"
                     id="sourceText">Nội dung trích dẫn...</div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ── State ─────────────────────────────────────────────────────
    let activeSessionId = null;
    let isFirstMessageInSession = true;

    const messagesContainer = document.getElementById('chatMessages');
    const antiForgeryToken   = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

    function scrollToBottom() {
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    // ── Lock / Unlock ─────────────────────────────────────────────
    function setChatLocked(locked, placeholderText) {
        const overlay = document.getElementById('chatLockOverlay');
        const input   = document.getElementById('chatInput');
        const btnSend = document.getElementById('btnSend');
        if (locked) {
            overlay.classList.remove('hidden');
            input.disabled = true;
            input.placeholder = placeholderText || 'Chọn hoặc tạo phiên hội thoại trước...';
            btnSend.disabled = true;
            
            // Cập nhật text trong lock overlay phù hợp
            const overlayTitle = overlay.querySelector('.chat-lock-text h6');
            const overlayDesc = overlay.querySelector('.chat-lock-text p');
            if (placeholderText && placeholderText.includes('môn học')) {
                if (overlayTitle) overlayTitle.textContent = 'Chọn môn học để trò chuyện';
                if (overlayDesc) overlayDesc.textContent = 'Vui lòng chọn môn học ở danh sách bên trái để giới hạn phạm vi tài liệu và bắt đầu trò chuyện với AI.';
            } else {
                if (overlayTitle) overlayTitle.textContent = 'Chọn hoặc tạo phiên hội thoại';
                if (overlayDesc) overlayDesc.textContent = 'Nhấn "Phiên mới" ở cột trái để bắt đầu cuộc hội thoại mới, hoặc chọn phiên cũ để xem lại.';
            }
        } else {
            overlay.classList.add('hidden');
            input.disabled = false;
            input.placeholder = 'Nhập câu hỏi học tập của bạn tại đây...';
            btnSend.disabled = false;
            input.focus();
        }
    }

    function updateChatLockState() {
        if (!activeSessionId) {
            setChatLocked(true, 'Chọn hoặc tạo phiên hội thoại trước...');
            return;
        }
        
        setChatLocked(false);
    }

    async function onSubjectChanged(subjectId) {
        loadChatChapters(subjectId);
        updateChatLockState();
        
        // Nếu có phiên đang hoạt động, tự động lưu môn học này vào DB cho phiên đó
        if (activeSessionId) {
            try {
                const form = new FormData();
                form.append('sessionId', activeSessionId);
                if (subjectId) form.append('subjectId', subjectId);
                form.append('__RequestVerificationToken', antiForgeryToken);
                
                await fetch('/Chat?handler=UpdateSessionSubject', { method: 'POST', body: form });
                
                // Tải lại danh sách phiên để đồng bộ thuộc tính subjectId trong JS
                await loadUserSessions();
                setActiveSessionItem(activeSessionId);
            } catch (e) {
                console.error('Failed to update session subject', e);
            }
        }
    }

    // ── Helpers ───────────────────────────────────────────────────
    function formatDate(iso) {
        const d = new Date(iso);
        const pad = n => String(n).padStart(2,'0');
        return `${pad(d.getDate())}/${pad(d.getMonth()+1)} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
    }

    function renderMarkdown(text) {
        let f = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
        f = f.replace(/\*(.*?)\*/g, '<em>$1</em>');
        const lines = f.split('\n');
        let inList = false;
        for (let i = 0; i < lines.length; i++) {
            if (lines[i].trim().startsWith('- ')) {
                const content = lines[i].trim().substring(2);
                lines[i] = inList ? `<li>${content}</li>` : `<ul><li>${content}</li>`;
                inList = true;
            } else if (lines[i].trim().startsWith('>') && lines[i].includes('"')) {
                const quote = lines[i].trim().substring(1).replace(/"/g,'').trim();
                lines[i] = `<blockquote class="border-start border-primary border-4 ps-3 py-1 my-2 bg-light text-muted" style="font-style:italic;">"${quote}"</blockquote>`;
            } else {
                if (inList) { lines[i] = '</ul>' + lines[i]; inList = false; }
            }
        }
        if (inList) lines[lines.length-1] += '</ul>';
        return lines.join('\n').replace(/\n/g, '<br/>');
    }

    function showSourceDetails(title, page, score, content) {
        document.getElementById('sourceDocTitle').textContent = title;
        document.getElementById('sourcePage').textContent = page ? 'Trang ' + page : 'Phân đoạn văn bản';
        document.getElementById('sourceScore').textContent = parseFloat(score).toFixed(1) + '% Độ tương đồng';
        document.getElementById('sourceText').textContent = content;
        new bootstrap.Modal(document.getElementById('sourceModal')).show();
    }

    // ── Session List Rendering ────────────────────────────────────
    function renderSessionList(sessions) {
        const list  = document.getElementById('sessionList');
        const empty = document.getElementById('sessionEmpty');

        // Remove all items except the empty placeholder
        Array.from(list.querySelectorAll('.session-item')).forEach(el => el.remove());

        if (!sessions || sessions.length === 0) {
            empty.style.display = 'block';
            return;
        }
        empty.style.display = 'none';

        sessions.forEach(s => {
            const item = document.createElement('div');
            item.className = 'session-item' + (s.sessionID === activeSessionId ? ' active' : '');
            item.dataset.sessionId = s.sessionID;
            item.innerHTML = `
                <div class="session-item-icon"><i class="bi bi-chat-text"></i></div>
                <div class="session-item-body" style="flex: 1; min-width: 0;">
                    <div class="d-flex justify-content-between align-items-baseline">
                        <div class="session-item-title" title="${escapeHtml(s.title)}" style="flex: 1; min-width: 0; text-align: left; font-weight: 600;">${escapeHtml(s.title)}</div>
                        <span class="session-item-date ms-2" style="flex-shrink: 0; font-size: 0.7rem; color: #94a3b8;">${formatDate(s.updatedAt)}</span>
                    </div>
                    <div class="session-item-preview text-muted small" style="text-align: left; font-size: 0.75rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%;">
                        ${escapeHtml(s.lastMessagePreview || 'Chưa có tin nhắn')}
                    </div>
                </div>
                <button class="btn-delete-session" onclick="deleteSession(event, ${s.sessionID})" title="Xóa phiên này">
                    <i class="bi bi-trash3"></i>
                </button>`;
            item.addEventListener('click', (e) => {
                if (!e.target.closest('.btn-delete-session')) loadSession(s.sessionID, s.title, s.subjectId);
            });
            list.insertBefore(item, empty);
        });
    }

    function escapeHtml(str) {
        return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function setActiveSessionItem(sessionId) {
        document.querySelectorAll('.session-item').forEach(el => {
            el.classList.toggle('active', parseInt(el.dataset.sessionId) === sessionId);
        });
    }

    async function loadUserSessions() {
        try {
            const res = await fetch('/Chat?handler=Sessions');
            const data = await res.json();
            renderSessionList(data);
            
            // Đồng bộ lại tiêu đề phiên hiện tại ở Header nếu tiêu đề đã đổi ở backend
            if (activeSessionId) {
                const activeSess = data.find(s => s.sessionID === activeSessionId);
                if (activeSess) {
                    document.getElementById('activeSessionTitle').textContent = activeSess.title;
                }
            }
        } catch(e) {
            console.error('Failed to load sessions', e);
        }
    }

    // ── Create new session ────────────────────────────────────────
    async function createNewSession() {
        const subjectId = document.getElementById('chatSubjectSelect').value || null;
        try {
            document.getElementById('btnNewSession').disabled = true;
            const form = new FormData();
            if (subjectId) form.append('subjectId', subjectId);
            form.append('__RequestVerificationToken', antiForgeryToken);

            const res  = await fetch('/Chat?handler=CreateSession', { method: 'POST', body: form });
            const sess = await res.json();

            if (sess.error) { alert(sess.error); return; }

            activeSessionId = sess.sessionID;
            isFirstMessageInSession = true;

            // Update header
            document.getElementById('activeSessionTitle').textContent = sess.title;

            // Clear messages area
            messagesContainer.innerHTML = `
                <div class="message assistant" id="welcomeMessage">
                    <div class="message-avatar">AI</div>
                    <div class="message-content">
                        <p>Phiên mới đã được tạo! Bạn có thể nhập câu hỏi để bắt đầu trò chuyện ngay, hoặc chọn môn học ở cột trái để giới hạn phạm vi tìm kiếm tài liệu. 🚀</p>
                    </div>
                </div>`;

            // Lock/unlock based on subject selection
            updateChatLockState();

            // Reload sessions list
            await loadUserSessions();
            setActiveSessionItem(activeSessionId);
        } catch(e) {
            console.error('Error creating session', e);
        } finally {
            document.getElementById('btnNewSession').disabled = false;
        }
    }

    // ── Load session messages ─────────────────────────────────────
    async function loadSession(sessionId, title, subjectId) {
        try {
            activeSessionId = sessionId;
            isFirstMessageInSession = false;

            document.getElementById('activeSessionTitle').textContent = title;
            setActiveSessionItem(sessionId);

            // Tự động chọn môn học đã lưu của phiên này
            const subjectSelect = document.getElementById('chatSubjectSelect');
            subjectSelect.value = subjectId || '';
            
            // Tải danh sách chương tương ứng và cập nhật trạng thái khóa chat
            loadChatChapters(subjectId);
            updateChatLockState();

            const res  = await fetch(`/Chat?handler=SessionMessages&sessionId=${sessionId}`);
            const msgs = await res.json();

            // Clear and render
            messagesContainer.innerHTML = '';

            if (msgs.length === 0) {
                messagesContainer.innerHTML = `
                    <div class="message assistant">
                        <div class="message-avatar">AI</div>
                        <div class="message-content"><p>Phiên này chưa có tin nhắn nào.</p></div>
                    </div>`;
            } else {
                msgs.forEach(m => appendMessage(m.role, m.content, m.sources, false, m));
            }

            scrollToBottom();
        } catch(e) {
            console.error('Error loading session', e);
        }
    }

    // ── Delete session ────────────────────────────────────────────
    async function deleteSession(event, sessionId) {
        event.stopPropagation();
        
        const result = await Swal.fire({
            title: 'Xóa phiên hội thoại?',
            text: 'Toàn bộ lịch sử tin nhắn trong phiên này sẽ bị xóa vĩnh viễn và không thể khôi phục.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Xóa',
            cancelButtonText: 'Hủy',
            background: 'rgba(255, 255, 255, 0.95)',
            backdrop: 'rgba(15, 23, 42, 0.3)'
        });

        if (!result.isConfirmed) return;

        try {
            const form = new FormData();
            form.append('sessionId', sessionId);
            form.append('__RequestVerificationToken', antiForgeryToken);

            await fetch('/Chat?handler=DeleteSession', { method: 'POST', body: form });

            if (activeSessionId === sessionId) {
                activeSessionId = null;
                document.getElementById('activeSessionTitle').textContent = 'Chưa chọn phiên';
                messagesContainer.innerHTML = `
                    <div class="message assistant">
                        <div class="message-avatar">AI</div>
                        <div class="message-content"><p>Phiên đã bị xóa. Hãy chọn hoặc tạo phiên mới.</p></div>
                    </div>`;
                setChatLocked(true);
            }

            await loadUserSessions();

            Swal.fire({
                title: 'Đã xóa!',
                text: 'Phiên hội thoại đã được xóa thành công.',
                icon: 'success',
                timer: 1500,
                showConfirmButton: false
            });
        } catch(e) {
            console.error('Error deleting session', e);
            Swal.fire({
                title: 'Lỗi!',
                text: 'Không thể xóa phiên hội thoại này.',
                icon: 'error'
            });
        }
    }

    // ── Filter: Load chapters ─────────────────────────────────────
    function loadChatChapters(subjectId) {
        const select = document.getElementById('chatChapterSelect');
        select.innerHTML = '<option value="">— Đang tải... —</option>';
        select.disabled = true;

        if (!subjectId) {
            select.innerHTML = '<option value="">— Tất cả chương —</option>';
            if (activeSessionId) setChatLocked(false);
            return;
        }

        if (activeSessionId) setChatLocked(false);

        fetch('/Documents/Index?handler=GetChapters&subjectId=' + subjectId)
            .then(r => r.json())
            .then(data => {
                select.innerHTML = '<option value="">— Tất cả chương —</option>';
                data.forEach(c => {
                    select.innerHTML += `<option value="${c.chapterID}">Chương ${c.chapterNumber}: ${c.chapterName}</option>`;
                });
                select.disabled = false;
            });
    }

    function resetChatFilters() {
        document.getElementById('chatSubjectSelect').value = '';
        const cs = document.getElementById('chatChapterSelect');
        cs.innerHTML = '<option value="">— Tất cả chương —</option>';
        cs.value = '';
        cs.disabled = true;
    }

    // ── Send message ──────────────────────────────────────────────
    function sendChatMessage(event) {
        event.preventDefault();
        if (!activeSessionId) { alert('Vui lòng chọn hoặc tạo phiên hội thoại trước!'); return; }

        const input = document.getElementById('chatInput');
        const questionText = input.value.trim();
        if (!questionText) return;

        input.value = '';
        input.disabled = true;
        document.getElementById('btnSend').disabled = true;

        appendMessage('user', questionText, null, false);
        const loadingId = appendLoadingIndicator();
        scrollToBottom();

        const targetSessionId = activeSessionId;
        const isFirst = isFirstMessageInSession;
        if (isFirst) {
            isFirstMessageInSession = false;
        }

        const formData = new FormData();
        formData.append('question', questionText);
        formData.append('subjectId', document.getElementById('chatSubjectSelect').value);
        formData.append('chapterId', document.getElementById('chatChapterSelect').value);
        formData.append('modelProvider', document.getElementById('modelProviderSelect').value);
        formData.append('__RequestVerificationToken', antiForgeryToken);

        fetch('/Chat?handler=Ask', { method: 'POST', body: formData })
            .then(r => r.json())
            .then(data => {
                removeLoadingIndicator(loadingId);
                
                if (activeSessionId === targetSessionId) {
                    appendMessage('assistant', data.answer, data.sources, false, data);
                    scrollToBottom();
                }

                // Save both messages and auto-rename session asynchronously in the background
                saveAndRefreshSessions(targetSessionId, questionText, data.answer, data.sources, isFirst, data);
            })
            .catch(err => {
                console.error(err);
                removeLoadingIndicator(loadingId);
                if (activeSessionId === targetSessionId) {
                    appendMessage('assistant', 'Đã xảy ra lỗi kết nối. Vui lòng thử lại.', null, false);
                    scrollToBottom();
                }
            })
            .finally(() => {
                input.disabled = false;
                document.getElementById('btnSend').disabled = false;
                input.focus();
            });
    }

    async function saveAndRefreshSessions(sessionId, userContent, assistantContent, sources, isFirst, meta) {
        try {
            const saveForm = new FormData();
            saveForm.append('sessionId', sessionId);
            saveForm.append('userContent', userContent);
            saveForm.append('assistantContent', assistantContent);
            if (sources && sources.length > 0) saveForm.append('sourcesJson', JSON.stringify(sources));
            if (meta && meta.providerName) {
                saveForm.append('providerName', meta.providerName);
                if (meta.modelName) saveForm.append('modelName', meta.modelName);
                if (meta.executionTimeMs !== undefined) saveForm.append('executionTimeMs', meta.executionTimeMs);
                if (meta.promptTokens !== undefined) saveForm.append('promptTokens', meta.promptTokens);
                if (meta.completionTokens !== undefined) saveForm.append('completionTokens', meta.completionTokens);
            }
            saveForm.append('__RequestVerificationToken', antiForgeryToken);

            if (isFirst) {
                const autoTitle = userContent.split(' ').slice(0, 6).join(' ') + (userContent.split(' ').length > 6 ? '...' : '');
                
                if (activeSessionId === sessionId) {
                    document.getElementById('activeSessionTitle').textContent = autoTitle;
                }
            }

            const saveRes = await fetch('/Chat?handler=SaveMessages', { method: 'POST', body: saveForm });
            const saveData = await saveRes.json();
            if (saveData && saveData.messageId) {
                const unlinkedFeedbacks = document.querySelectorAll('.message-feedback[data-msg-id="0"], .message-feedback[data-msg-id=""]');
                if (unlinkedFeedbacks && unlinkedFeedbacks.length > 0) {
                    const lastFb = unlinkedFeedbacks[unlinkedFeedbacks.length - 1];
                    lastFb.setAttribute('data-msg-id', saveData.messageId);
                    const buttons = lastFb.querySelectorAll('button');
                    if (buttons[0]) buttons[0].setAttribute('onclick', `rateMessage(${saveData.messageId}, 1, this)`);
                    if (buttons[1]) buttons[1].setAttribute('onclick', `rateMessage(${saveData.messageId}, -1, this)`);
                }
            }


            if (activeSessionId === sessionId) {
                const ind = document.getElementById('saveIndicator');
                if (ind) {
                    ind.style.display = 'flex';
                    setTimeout(() => { ind.style.display = 'none'; }, 2000);
                }
            }

            // Refresh session list once
            await loadUserSessions();
            setActiveSessionItem(activeSessionId);
        } catch(e) {
            console.error('Failed to save messages/rename session in background', e);
        }
    }

    // ── Feedback rate function ────────────────────────────────────
    async function rateMessage(messageId, feedback, btn) {
        if (!messageId || messageId === 0) {
            const container = btn.closest('.message-feedback');
            if (container && container.dataset.msgId && parseInt(container.dataset.msgId) > 0) {
                messageId = parseInt(container.dataset.msgId);
            } else {
                Swal.fire({ icon: 'info', title: 'Thông báo', text: 'Tin nhắn đang được đồng bộ, vui lòng nhấp lại sau giây lát.' });
                return;
            }
        }
        try {
            const form = new FormData();
            form.append('messageId', messageId);
            form.append('feedback', feedback);
            form.append('__RequestVerificationToken', antiForgeryToken);

            const res = await fetch('/Chat?handler=Feedback', { method: 'POST', body: form });
            const data = await res.json();
            if (data.ok) {
                const container = btn.closest('.message-feedback');
                if (container) {
                    const buttons = container.querySelectorAll('button');
                    const upBtn = buttons[0];
                    const downBtn = buttons[1];
                    
                    if (feedback === 1) {
                        upBtn.className = 'btn btn-sm py-1 px-2 border border-success rounded bg-white text-success fw-bold shadow-sm';
                        upBtn.innerHTML = '<i class="bi bi-hand-thumbs-up-fill fs-6 text-success me-1"></i> Hữu ích';
                        downBtn.className = 'btn btn-sm py-1 px-2 border rounded bg-white text-secondary shadow-sm';
                        downBtn.innerHTML = '<i class="bi bi-hand-thumbs-down fs-6"></i>';
                    } else if (feedback === -1) {
                        downBtn.className = 'btn btn-sm py-1 px-2 border border-danger rounded bg-white text-danger fw-bold shadow-sm';
                        downBtn.innerHTML = '<i class="bi bi-hand-thumbs-down-fill fs-6 text-danger me-1"></i> Chưa tốt';
                        upBtn.className = 'btn btn-sm py-1 px-2 border rounded bg-white text-secondary shadow-sm';
                        upBtn.innerHTML = '<i class="bi bi-hand-thumbs-up fs-6"></i>';
                    }
                }
                const Toast = Swal.mixin({ toast: true, position: 'bottom-end', showConfirmButton: false, timer: 2000 });
                Toast.fire({ icon: 'success', title: 'Đã ghi nhận đánh giá của bạn!' });
            }
        } catch(e) {
            console.error('Error rating message', e);
        }
    }

    // ── Message rendering ─────────────────────────────────────────
    function appendMessage(sender, text, sources, _unused, meta = null) {
        const messageDiv = document.createElement('div');
        messageDiv.className = `message ${sender}`;

        const avatarDiv = document.createElement('div');
        avatarDiv.className = 'message-avatar';
        avatarDiv.textContent = sender === 'user' ? 'U' : 'AI';

        const contentDiv = document.createElement('div');
        contentDiv.className = 'message-content';
        contentDiv.innerHTML = renderMarkdown(text);

        if (sources && sources.length > 0) {
            const sourcesDiv = document.createElement('div');
            sourcesDiv.className = 'message-sources';
            sourcesDiv.innerHTML = '<span class="text-muted d-block w-100 mb-1 small"><i class="bi bi-info-circle me-1"></i>Trích dẫn từ tài liệu học tập:</span>';

            const uniqueSources = [];
            sources.forEach(src => {
                const key = `${src.documentTitle}_${src.pageNumber ?? 'N/A'}`;
                const existing = uniqueSources.find(x => `${x.documentTitle}_${x.pageNumber ?? 'N/A'}` === key);
                if (existing) {
                    existing.contentSnippet += "\n\n[Đoạn trích liên quan khác]:\n" + src.contentSnippet;
                    if (src.similarityScore > existing.similarityScore) existing.similarityScore = src.similarityScore;
                } else {
                    uniqueSources.push({ ...src });
                }
            });

            uniqueSources.forEach(src => {
                const cleanSnippet = src.contentSnippet.replace(/'/g, "\\'").replace(/"/g, '&quot;');
                sourcesDiv.innerHTML += `
                    <div class="source-tag" onclick="showSourceDetails('${src.documentTitle}', ${src.pageNumber}, ${src.similarityScore}, '${cleanSnippet}')">
                        <i class="bi bi-file-earmark-text-fill"></i>
                        <span>${src.documentTitle.length > 35 ? src.documentTitle.substring(0,32)+'...' : src.documentTitle}</span>
                        ${src.pageNumber ? `<span class="text-secondary small">(Tr.${src.pageNumber})</span>` : ''}
                    </div>`;
            });
            contentDiv.appendChild(sourcesDiv);
        }

        if (sender === 'assistant') {
            const benchDiv = document.createElement('div');
            benchDiv.className = 'message-benchmark mt-3 pt-2 border-top d-flex align-items-center justify-content-between flex-wrap gap-2';
            benchDiv.style.cssText = 'font-size: 0.75rem; color: #64748b; border-color: rgba(0,0,0,0.08) !important;';
            
            const provider = (meta && meta.providerName) ? meta.providerName : 'Gemini';
            const model = (meta && meta.modelName) ? meta.modelName : 'gemini-2.5-flash';
            const time = (meta && meta.executionTimeMs !== null && meta.executionTimeMs !== undefined) ? `${Math.round(meta.executionTimeMs)} ms` : 'N/A';
            const pTokens = (meta && meta.promptTokens !== null && meta.promptTokens !== undefined) ? meta.promptTokens : 0;
            const cTokens = (meta && meta.completionTokens !== null && meta.completionTokens !== undefined) ? meta.completionTokens : 0;
            const msgId = (meta && meta.messageID) ? meta.messageID : 0;
            const fb = (meta && meta.feedback) ? meta.feedback : 0;

            let providerBadgeClass = 'bg-primary-subtle text-primary border-primary-subtle';
            if (provider === 'OpenAI') providerBadgeClass = 'bg-success-subtle text-success border-success-subtle';
            else if (provider === 'Groq') providerBadgeClass = 'bg-warning-subtle text-dark border-warning-subtle';

            const totalTokens = pTokens + cTokens;

            const upClass = fb === 1 ? 'btn btn-sm py-1 px-2 border border-success rounded bg-white text-success fw-bold shadow-sm' : 'btn btn-sm py-1 px-2 border rounded bg-white text-secondary shadow-sm';
            const downClass = fb === -1 ? 'btn btn-sm py-1 px-2 border border-danger rounded bg-white text-danger fw-bold shadow-sm' : 'btn btn-sm py-1 px-2 border rounded bg-white text-secondary shadow-sm';
            const upIcon = fb === 1 ? '<i class="bi bi-hand-thumbs-up-fill fs-6 text-success me-1"></i> Hữu ích' : '<i class="bi bi-hand-thumbs-up fs-6"></i>';
            const downIcon = fb === -1 ? '<i class="bi bi-hand-thumbs-down-fill fs-6 text-danger me-1"></i> Chưa tốt' : '<i class="bi bi-hand-thumbs-down fs-6"></i>';

            benchDiv.innerHTML = `
                <div class="d-flex align-items-center flex-wrap gap-2">
                    <span class="badge ${providerBadgeClass} border fw-semibold"><i class="bi bi-cpu-fill me-1"></i>${provider} (${model})</span>
                    <span><i class="bi bi-stopwatch me-1"></i>${time}</span>
                    <span><i class="bi bi-lightning-charge me-1"></i>Tokens: <strong>${pTokens}</strong> in / <strong>${cTokens}</strong> out</span>
                </div>
                <div class="w-100 mt-1" style="font-size:0.7rem; color:#94a3b8; font-style:italic;">
                    Được trả lời bởi ${model} qua ${provider} trong ${time} • Sử dụng ${totalTokens} tokens
                </div>
                <div class="message-feedback d-flex align-items-center gap-1 mt-1" data-msg-id="${msgId}">
                    <span class="me-1 text-secondary fw-semibold">Đánh giá:</span>
                    <button type="button" class="${upClass}" title="Hữu ích" onclick="rateMessage(${msgId}, 1, this)">${upIcon}</button>
                    <button type="button" class="${downClass}" title="Không hữu ích" onclick="rateMessage(${msgId}, -1, this)">${downIcon}</button>
                </div>`;
            contentDiv.appendChild(benchDiv);
        }

        messageDiv.appendChild(avatarDiv);
        messageDiv.appendChild(contentDiv);
        messagesContainer.appendChild(messageDiv);
        scrollToBottom();
    }

    function appendLoadingIndicator() {
        const id = 'loading_' + Date.now();
        const div = document.createElement('div');
        div.className = 'message assistant';
        div.id = id;
        div.innerHTML = `
            <div class="message-avatar">AI</div>
            <div class="message-content">
                <div class="thinking">
                    <div class="dot"></div><div class="dot"></div><div class="dot"></div>
                    <span class="text-muted small ms-2">Đang phân tích tài liệu...</span>
                </div>
            </div>`;
        messagesContainer.appendChild(div);
        return id;
    }

    function removeLoadingIndicator(id) {
        const el = document.getElementById(id);
        if (el) el.remove();
    }

    // ── Model Provider Selector (Tab/Card style) ───────────────
    function selectModelProvider(card) {
        if (card.classList.contains('package-locked')) {
            window.location.href = '/Packages';
            return;
        }
        // Remove active state from all options
        document.querySelectorAll('#modelDropdownMenu .model-option').forEach(c => {
            c.classList.remove('active');
        });

        // Set active state on selected option
        card.classList.add('active');

        // Update hidden input value
        const provider = card.dataset.provider;
        const name = card.dataset.name || card.dataset.provider;
        const icon = card.dataset.icon || '✨';

        document.getElementById('modelProviderSelect').value = provider;
        const nameEl = document.getElementById('selectedModelName');
        if (nameEl) nameEl.textContent = name;
        const iconEl = document.getElementById('selectedModelIcon');
        if (iconEl) iconEl.textContent = icon;

        // Hide dropdown menu after selecting
        const menu = document.getElementById('modelDropdownMenu');
        if (menu) menu.classList.add('hidden');

        // Persist to localStorage
        try { localStorage.setItem('lds_selected_model_provider', provider); } catch(e) {}
    }

    function toggleModelDropdown(event) {
        if (event) event.stopPropagation();
        const menu = document.getElementById('modelDropdownMenu');
        if (menu) menu.classList.toggle('hidden');
    }

    document.addEventListener('click', function(event) {
        const container = event.target.closest('.model-dropdown-container');
        if (!container) {
            const menu = document.getElementById('modelDropdownMenu');
            if (menu && !menu.classList.contains('hidden')) {
                menu.classList.add('hidden');
            }
        }
    });

    // ── Restore model selection from localStorage ────────────────
    (function restoreModelSelection() {
        try {
            const allowedProviders = @Html.Raw(allowedProviders);
            document.querySelectorAll('#modelDropdownMenu .model-option').forEach(card => {
                if (!allowedProviders.some(provider => provider.toLowerCase() === card.dataset.provider.toLowerCase())) {
                    card.classList.add('package-locked');
                    card.style.opacity = '0.45';
                    card.style.cursor = 'not-allowed';
                    const badge = card.querySelector('.model-option-badge');
                    if (badge) badge.textContent = 'Nang cap';
                }
            });

            const saved = localStorage.getItem('lds_selected_model_provider');
            if (saved && allowedProviders.some(provider => provider.toLowerCase() === saved.toLowerCase())) {
                const card = document.querySelector(`#modelDropdownMenu .model-option[data-provider="${saved}"]`);
                if (card) {
                    selectModelProvider(card);
                }
            }
        } catch(e) {}
    })();

    // ── Init ──────────────────────────────────────────────────────
    loadUserSessions();
    scrollToBottom();
</script>
}
