@page "{id:int}"
@model DetailsModel
@{
    ViewData["Title"] = "Chi tiết chương học";
}

<div id="chapter-detail-content">
<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-journal-bookmark-fill me-2"></i>Chi tiết chương học</h1>
        <p class="page-subtitle">Thông tin chương @Model.Chapter.ChapterNumber - @Model.Chapter.ChapterName</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="./Index" asp-route-subjectId="@Model.Chapter.SubjectID" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
        @if (User.IsInRole("Teacher"))
        {
            <a asp-page="./Edit" asp-route-id="@Model.Chapter.ChapterID" class="btn btn-warning">
                <i class="bi bi-pencil-fill me-1"></i> Sửa chương học
            </a>
        }
    </div>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card-custom mb-4">
            <div class="card-custom-header">
                <h5>Thông tin chương học</h5>
            </div>
            <div class="card-custom-body">
                <div class="mb-3">
                    <label class="text-muted small d-block">Môn học</label>
                    <span class="fw-semibold">@Model.Chapter.SubjectName</span>
                </div>
                <div class="mb-3">
                    <label class="text-muted small d-block">Số thứ tự chương</label>
                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill fs-6 px-3">
                        Chương @Model.Chapter.ChapterNumber
                    </span>
                </div>
                <div class="mb-3">
                    <label class="text-muted small d-block">Tên chương học</label>
                    <span class="fw-semibold fs-5">@Model.Chapter.ChapterName</span>
                </div>
                <div class="mb-0">
                    <label class="text-muted small d-block">Số lượng tài liệu</label>
                    <a asp-page="/Documents/Index" asp-route-chapterId="@Model.Chapter.ChapterID" class="badge bg-secondary-subtle text-secondary fs-6 px-3 text-decoration-none">
                        <i class="bi bi-file-earmark me-1"></i>@Model.Chapter.DocumentCount tài liệu
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
<script>
    document.addEventListener("realtimeUpdate", function(e) {
        const type = e.detail.messageType;
        const payload = e.detail.payload;
        const currentChapterId = @Model.Chapter.ChapterID;

        if (type.startsWith("Chapter")) {
            if (type === "ChapterDeleted" && payload.chapterId === currentChapterId) {
                console.log("Current chapter deleted in realtime. Redirecting...");
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Chương học đã bị xóa',
                        text: 'Chương học này đã bị xóa bởi người dùng khác. Bạn sẽ được chuyển hướng về danh sách.',
                        timer: 3000,
                        showConfirmButton: false
                    }).then(() => {
                        window.location.href = '/Chapters/Index';
                    });
                } else {
                    window.location.href = '/Chapters/Index';
                }
            } else {
                console.log("Chapter updated. Refreshing details...");
                setTimeout(() => {
                    refreshPageFragments(["#chapter-detail-content"])
                        .catch(err => console.error("Chapter detail realtime refresh failed:", err));
                }, 1000);
            }
        } else if (type.startsWith("Subject")) {
            // Refresh if parent subject changes (since subject name is shown)
            console.log("Parent subject changed. Refreshing chapter details...");
            setTimeout(() => {
                refreshPageFragments(["#chapter-detail-content"])
                    .catch(err => console.error("Chapter detail realtime refresh failed:", err));
            }, 1000);
        }
    });
</script>
}
