@page
@model IndexModel
@using LearningDocumentSystem.Common.Constants
@{
    ViewData["Title"] = "Người dùng";
}

<!-- Anti-forgery token for AJAX requests -->
@Html.AntiForgeryToken()

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title"><i class="bi bi-people-fill me-2"></i>Người dùng</h1>
        <p class="page-subtitle">Quản lý tài khoản người dùng và gán môn học</p>
    </div>
    <div>
        <a asp-page="/Users/Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-person-plus-fill me-1"></i>Thêm Giảng viên
        </a>
    </div>
</div>

<div class="card-custom">
    <!-- Search & Filter Controls -->
    <div class="row g-3 p-3 pb-0">
        <div class="col-md-8 col-lg-6">
            <div class="input-group shadow-sm rounded">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="userSearchInput" class="form-control border-start-0" placeholder="Tìm kiếm theo tài khoản, họ tên hoặc email..." />
            </div>
        </div>
        <div class="col-md-4 col-lg-3">
            <select id="roleFilterSelect" class="form-select shadow-sm">
                <option value="">Tất cả Role</option>
                <option value="Teacher">Teacher</option>
                <option value="Student">Student</option>
            </select>
        </div>
    </div>

    <div class="card-custom-body p-0 mt-3" id="users-list-panel">
        @if (!Model.ModelData.Users.Any())
        {
            <div class="empty-state py-5">
                <i class="bi bi-people"></i>
                <p>Không có tài khoản nào</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover table-clean mb-0 align-middle">
                    <thead class="table-light text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 0.05em;">
                        <tr>
                            <th style="width: 60px;">#</th>
                            <th>Tài khoản</th>
                            <th>Họ tên</th>
                            <th>Email</th>
                            <th>Trạng thái</th>
                            <th>Role</th>
                            <th class="text-center" style="width: 250px;">Subject</th>
                            <th class="text-end" style="width: 200px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int idx = 1; }
                        @foreach (var u in Model.ModelData.Users)
                        {
                            var isAdminUser = u.Roles.Contains(AppConstants.RoleAdmin);
                            var currentRole = u.Roles.Contains(AppConstants.RoleAdmin) ? "Admin" : (u.Roles.Contains(AppConstants.RoleTeacher) ? "Teacher" : "Student");
                            
                            <tr class="user-row" data-fullname="@u.FullName" data-username="@u.Username" data-email="@u.Email" data-current-role="@currentRole">
                                <td class="text-muted">@(idx++)</td>
                                <td class="fw-semibold">@u.Username</td>
                                <td>@u.FullName</td>
                                <td>@u.Email</td>
                                <td>
                                    @if (u.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">Khóa</span>
                                    }
                                </td>
                                <td>
                                    @if (currentRole == "Admin")
                                    {
                                        <span class="badge bg-dark-subtle text-dark">Admin</span>
                                    }
                                    else if (currentRole == "Teacher")
                                    {
                                        <span class="badge bg-info-subtle text-info">Teacher</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">Student</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (currentRole == "Teacher")
                                    {
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" id="assignSubjectBtn_@u.UserID" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside">
                                                — Gán môn —
                                            </button>
                                            <ul class="dropdown-menu p-2 shadow" aria-labelledby="assignSubjectBtn_@u.UserID" style="min-width: 280px; max-height: 300px; overflow-y: auto;">
                                                @foreach (var subject in Model.ModelData.AllSubjects)
                                                {
                                                    var isAssigned = u.AssignedSubjectIds.Contains(subject.SubjectID);
                                                    var isAssignedToOther = subject.SubjectLeaderID.HasValue && subject.SubjectLeaderID != u.UserID;
                                                    var assignedToText = isAssignedToOther ? $" (đã giao: {(subject.SubjectLeaderName ?? "Người khác")})" : "";
                                                    <li>
                                                        <div class="form-check">
                                                            <input class="form-check-input subject-checkbox" type="checkbox" 
                                                                   value="@subject.SubjectID" 
                                                                   id="subject_@(u.UserID)_@(subject.SubjectID)"
                                                                   data-user-id="@u.UserID"
                                                                   @(isAssigned ? "checked" : "")
                                                                   @(isAssignedToOther ? "disabled" : "")>
                                                            <label class="form-check-label @(isAssignedToOther ? "text-muted" : "")" for="subject_@(u.UserID)_@(subject.SubjectID)" style="font-size: 0.85rem;">
                                                                @subject.SubjectName <span style="font-size: 0.75rem;">@assignedToText</span>
                                                            </label>
                                                        </div>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-page="/Users/Details" asp-route-id="@u.UserID" class="btn btn-outline-info" title="Chi tiết">
                                            <i class="bi bi-info-circle-fill"></i>
                                        </a>
                                        @if (!isAdminUser)
                                        {
                                            <a asp-page="/Users/Edit" asp-route-id="@u.UserID" class="btn btn-outline-warning" title="Sửa vai trò">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>
                                            <a asp-page="/Users/Delete" asp-route-id="@u.UserID" class="btn btn-outline-danger" title="Xóa tài khoản">
                                                <i class="bi bi-trash"></i> Xóa
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Retrieve anti-forgery token from the page
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        function bindSubjectCheckboxes() {
            document.querySelectorAll('.subject-checkbox').forEach(checkbox => {
                checkbox.addEventListener('change', function() {
                    const userId = this.getAttribute('data-user-id');
                    const subjectId = this.value;
                    const isChecked = this.checked;
                    
                    // Immediately disable/enable this subject in other teachers' dropdowns
                    document.querySelectorAll(`.subject-checkbox[value="${subjectId}"]`).forEach(cb => {
                        if (cb.getAttribute('data-user-id') !== userId) {
                            cb.disabled = isChecked;
                        }
                    });

                    // get all checked checkboxes for this user
                    const checkedBoxes = document.querySelectorAll(`.subject-checkbox[data-user-id="${userId}"]:checked`);
                    const subjectIds = Array.from(checkedBoxes).map(cb => cb.value);
                    
                    const formData = new FormData();
                    formData.append('userId', userId);
                    subjectIds.forEach(id => formData.append('subjectIds', id));
                    if (token) {
                        formData.append('__RequestVerificationToken', token);
                    }
                    
                    fetch('/Users/Index?handler=AssignSubjects', {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => {
                        if (!response.ok) {
                            alert('Đã xảy ra lỗi khi gán môn học.');
                            this.checked = !this.checked; // Revert checkbox state
                            // Revert immediate client-side state
                            document.querySelectorAll(`.subject-checkbox[value="${subjectId}"]`).forEach(cb => {
                                if (cb.getAttribute('data-user-id') !== userId) {
                                    cb.disabled = !isChecked;
                                }
                            });
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Đã xảy ra lỗi kết nối khi gán môn học.');
                        this.checked = !this.checked; // Revert checkbox state
                        // Revert immediate client-side state
                        document.querySelectorAll(`.subject-checkbox[value="${subjectId}"]`).forEach(cb => {
                            if (cb.getAttribute('data-user-id') !== userId) {
                                cb.disabled = !isChecked;
                            }
                        });
                    });
                });
            });
        }

        // Client-side search and filtering logic
        const searchInput = document.getElementById('userSearchInput');
        const roleFilter = document.getElementById('roleFilterSelect');

        function filterUsers() {
            const searchTerm = searchInput.value.toLowerCase().trim();
            const selectedRole = roleFilter.value;

            document.querySelectorAll('.user-row').forEach(row => {
                const fullname = (row.getAttribute('data-fullname') || '').toLowerCase();
                const username = (row.getAttribute('data-username') || '').toLowerCase();
                const email = (row.getAttribute('data-email') || '').toLowerCase();
                const currentRole = row.getAttribute('data-current-role') || '';

                const matchesSearch = fullname.includes(searchTerm) || 
                                      username.includes(searchTerm) || 
                                      email.includes(searchTerm);
                
                const matchesRole = !selectedRole || currentRole === selectedRole;

                if (matchesSearch && matchesRole) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        bindSubjectCheckboxes();
        if (searchInput) searchInput.addEventListener('input', filterUsers);
        if (roleFilter) roleFilter.addEventListener('change', filterUsers);

        // Realtime update listener to refresh users list without full page reload
        document.addEventListener("realtimeUpdate", function(e) {
            const type = e.detail.messageType;
            if (type === "UserChanged" || type === "SubjectAssigned" || type === "SubjectCreated" || type === "SubjectUpdated" || type === "SubjectDeleted") {
                console.log("Realtime event matched in Users Index. Refreshing table...", type);
                
                // Track if any dropdown is currently open so we can restore it after refresh
                const openDropdown = document.querySelector('.dropdown-toggle.show');
                const openDropdownId = openDropdown ? openDropdown.id : null;

                setTimeout(() => {
                    refreshPageFragments(["#users-list-panel"], function() {
                        bindSubjectCheckboxes();
                        filterUsers();

                        // Restore open dropdown if it existed
                        if (openDropdownId) {
                            const btn = document.getElementById(openDropdownId);
                            if (btn && typeof bootstrap !== 'undefined') {
                                const dp = new bootstrap.Dropdown(btn);
                                dp.show();
                            }
                        }
                    }).catch(err => console.error("Users realtime refresh failed:", err));
                }, 300);
            }
        });
    </script>
}
