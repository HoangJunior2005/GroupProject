@page
@model CreateModel
@{
    ViewData["Title"] = "Thêm Giảng viên";
}

<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-person-plus-fill me-2"></i>
        @ViewData["Title"]
    </h1>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card-custom">
            <div class="card-custom-body">
                <form method="post">
                    @Html.AntiForgeryToken()
                    
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>
                    }

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-semibold">Email Giảng viên</label>
                        <input asp-for="Input.Email" class="form-control form-control-lg" placeholder="example@university.edu.vn"/>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        <div class="form-text">Email dùng để đăng nhập và nhận thông tin tài khoản.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.FullName" class="form-label fw-semibold">Họ và tên</label>
                        <input asp-for="Input.FullName" class="form-control form-control-lg" placeholder="Nguyễn Văn A"/>
                        <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label fw-semibold">Mật khẩu khởi tạo</label>
                        <div class="input-group">
                            <input asp-for="Input.Password" class="form-control form-control-lg" placeholder="******"/>
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('Input_Password', 'teacherPwdIcon')">
                                <i class="bi bi-eye" id="teacherPwdIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        <div class="form-text">Mật khẩu phải chứa ít nhất 6 ký tự.</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold">Nhập lại mật khẩu</label>
                        <div class="input-group">
                            <input asp-for="Input.ConfirmPassword" class="form-control form-control-lg" placeholder="******"/>
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('Input_ConfirmPassword', 'teacherConfirmPwdIcon')">
                                <i class="bi bi-eye" id="teacherConfirmPwdIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>
                            Tạo tài khoản
                        </button>
                        <a asp-page="./Index" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function togglePassword(inputId, iconId) {
            const pwdInput = document.getElementById(inputId);
            const pwdIcon = document.getElementById(iconId);
            if (pwdInput.type === 'password') {
                pwdInput.type = 'text';
                pwdIcon.className = 'bi bi-eye-slash';
            } else {
                pwdInput.type = 'password';
                pwdIcon.className = 'bi bi-eye';
            }
        }
    </script>
}
