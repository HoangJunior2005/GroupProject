@page
@model CreateModel
@{
    ViewData["Title"] = "Thêm môn học";
}

<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-plus-circle-fill me-2"></i>
        @ViewData["Title"]
    </h1>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card-custom">
            <div class="card-custom-body">
                <form method="post">
                    @Html.AntiForgeryToken()
                    
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>
                    }

                    <div class="mb-4">
                        <label asp-for="Input.SubjectName" class="form-label fw-semibold"></label>
                        <input asp-for="Input.SubjectName" class="form-control form-control-lg"
                               placeholder="VD: Lập trình cấu trúc C#"/>
                        <span asp-validation-for="Input.SubjectName" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.SubjectCode" class="form-label fw-semibold"></label>
                        <input asp-for="Input.SubjectCode" class="form-control form-control-lg"
                               placeholder="VD: INF205" style="text-transform: uppercase;"
                               oninput="this.value = this.value.toUpperCase()"/>
                        <span asp-validation-for="Input.SubjectCode" class="text-danger small"></span>
                        <div class="form-text">Chỉ gồm chữ hoa và số (VD: INF205, CS101)</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.SubjectLeaderID" class="form-label fw-semibold"></label>
                        <select asp-for="Input.SubjectLeaderID" asp-items="@(new SelectList(Model.Input.Teachers, "UserID", "FullName"))" class="form-select form-select-lg">
                            <option value="">-- Chọn giảng viên phụ trách --</option>
                        </select>
                        <span asp-validation-for="Input.SubjectLeaderID" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-1"></i>
                            Tạo môn học
                        </button>
                        <a asp-page="./Index" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
