@page "{id:int}"
@model DetailsModel
@{
    ViewData["Title"] = "Chi tiết môn học";
}

<div id="subject-detail-content">
<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-book-fill me-2"></i>Chi tiết môn học</h1>
        <p class="page-subtitle">Thông tin chi tiết về môn học @Model.Subject.SubjectName</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="./Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
        @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
        {
            <a asp-page="./Edit" asp-route-id="@Model.Subject.SubjectID" class="btn btn-warning">
                <i class="bi bi-pencil-fill me-1"></i> Sửa môn học
            </a>
        }
    </div>
</div>

<div class="row">
    <div class="col-lg-4">
        <div class="card-custom mb-4">
            <div class="card-custom-header">
                <h5>Thông tin chung</h5>
            </div>
            <div class="card-custom-body">
                <div class="mb-3">
                    <label class="text-muted small d-block">Tên môn học</label>
                    <span class="fw-semibold">@Model.Subject.SubjectName</span>
                </div>
                <div class="mb-3">
                    <label class="text-muted small d-block">Mã học phần</label>
                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill fs-6 px-3">
                        @Model.Subject.SubjectCode
                    </span>
                </div>
                <div class="mb-3">
                    <label class="text-muted small d-block">Số lượng chương học</label>
                    <span class="badge bg-secondary-subtle text-secondary">
                        @Model.Subject.ChapterCount chương
                    </span>
                </div>
                <div class="mb-0">
                    <label class="text-muted small d-block">Ngày khởi tạo</label>
                    <span class="text-muted">@Model.Subject.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-8">
        <div class="card-custom">
            <div class="card-custom-header d-flex justify-content-between align-items-center">
                <h5>Danh sách chương học</h5>
                <a asp-page="/Chapters/Index" asp-route-subjectId="@Model.Subject.SubjectID" class="btn btn-sm btn-outline-primary">
                    Quản lý Chương học <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="card-custom-body p-0">
                <div class="p-3 border-bottom text-muted small">
                    Môn học này có @Model.Subject.ChapterCount chương học được đăng ký. Bạn có thể nhấn trực tiếp vào chương học để quản lý tài liệu chi tiết.
                </div>
                <!-- Ở đây s.GetWithChaptersAsync() trả về thông tin môn học và số chương. -->
                <div class="p-4 text-center text-muted">
                    <i class="bi bi-journal-text fs-2 mb-2 d-block"></i>
                    Nhấn nút <strong>Quản lý Chương học</strong> ở góc trên để xem chi tiết danh sách chương hoặc tải lên tài liệu thuộc môn học này.
                </div>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
<script>
    document.addEventListener("realtimeUpdate", function(e) {
        const type = e.detail.messageType;
        const payload = e.detail.payload;
        const currentSubjectId = @Model.Subject.SubjectID;

        if (type.startsWith("Subject")) {
            if (type === "SubjectDeleted" && payload.subjectId === currentSubjectId) {
                console.log("Current subject deleted in realtime. Redirecting...");
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Môn học đã bị xóa',
                        text: 'Môn học này đã bị xóa bởi người dùng khác. Bạn sẽ được chuyển hướng về danh sách.',
                        timer: 3000,
                        showConfirmButton: false
                    }).then(() => {
                        window.location.href = '/Subjects/Index';
                    });
                } else {
                    window.location.href = '/Subjects/Index';
                }
            } else {
                console.log("Subject updated. Refreshing details...");
                setTimeout(() => {
                    refreshPageFragments(["#subject-detail-content"])
                        .catch(err => console.error("Subject detail realtime refresh failed:", err));
                }, 1000);
            }
        }
    });
</script>
}
