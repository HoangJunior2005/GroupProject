@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h1>
        <p class="page-subtitle">Tổng quan hệ thống tài liệu học tập</p>
    </div>
</div>

<!-- Stats Cards -->
@{
    var cardClass = User.IsInRole("Teacher") ? "col-xl-6 col-md-6" : "col-xl-4 col-md-4";
}
<div class="row g-4 mb-4" id="dashboard-stats-panel">
    <div class="@cardClass">
        <div class="stat-card stat-card-primary">
            <div class="stat-icon"><i class="bi bi-file-earmark-text-fill"></i></div>
            <div class="stat-content">
                <div class="stat-number">@Model.Dashboard.TotalDocuments</div>
                <div class="stat-label">Tổng tài liệu</div>
            </div>
        </div>
    </div>
    <div class="@cardClass">
        <div class="stat-card stat-card-warning">
            <div class="stat-icon"><i class="bi bi-journal-bookmark-fill"></i></div>
            <div class="stat-content">
                <div class="stat-number">@Model.Dashboard.TotalSubjects</div>
                <div class="stat-label">Môn học</div>
            </div>
        </div>
    </div>
    @if (!User.IsInRole("Teacher"))
    {
        <div class="@cardClass">
            <div class="stat-card stat-card-info">
                <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
                <div class="stat-content">
                    <div class="stat-number">@Model.Dashboard.TotalUsers</div>
                    <div class="stat-label">Người dùng</div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Charts Section -->
<div class="row g-4 mb-4">
    <div class="@(User.IsInRole("Admin") ? "col-lg-6" : "col-12")">
        <div class="card-custom">
            <div class="card-custom-header">
                <h5><i class="bi bi-graph-up-arrow me-2"></i>Tài liệu upload hàng tháng</h5>
                <span class="badge bg-primary-subtle text-primary">12 tháng gần nhất</span>
            </div>
            <div class="card-custom-body">
                <div style="position: relative; height: 300px;">
                    <canvas id="monthlyUploadChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <div class="col-lg-6">
            <div class="card-custom">
                <div class="card-custom-header">
                    <h5><i class="bi bi-people-fill me-2"></i>Người dùng đăng ký mới</h5>
                    <span class="badge bg-info-subtle text-info">12 tháng gần nhất</span>
                </div>
                <div class="card-custom-body">
                    <div style="position: relative; height: 300px;">
                        <canvas id="monthlyRegistrationChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!User.IsInRole("Admin"))
{
<!-- Index Status + Recent Docs -->
<div class="row g-4" id="dashboard-status-docs-panel">
    <div class="col-lg-5">
        <div class="card-custom">
            <div class="card-custom-header">
                <h5><i class="bi bi-bar-chart-fill me-2"></i>Trạng thái xử lý</h5>
            </div>
            <div class="card-custom-body">
                @{
                    void StatusRow(string label, int count, string color) {
                        var pct = Model.Dashboard.TotalDocuments > 0 ? count * 100 / Model.Dashboard.TotalDocuments : 0;
                        <div class="status-item mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="status-label">
                                    <span class="status-dot @color"></span> @label
                                </span>
                                <strong>@count</strong>
                            </div>
                            <div class="progress progress-custom">
                                <div class="progress-bar @color" style="width: @pct%"></div>
                            </div>
                        </div>
                    }
                }
                @{ StatusRow("Đã index",    Model.Dashboard.IndexedDocuments,    "bg-success"); }
                @{ StatusRow("Chờ xử lý",  Model.Dashboard.PendingDocuments,    "bg-warning"); }
                @{ StatusRow("Đang xử lý", Model.Dashboard.ProcessingDocuments,  "bg-info");    }
                @{ StatusRow("Thất bại",   Model.Dashboard.FailedDocuments,     "bg-danger");  }

                <div class="ai-ready-badge mt-4">
                    <i class="bi bi-cpu-fill me-2"></i>
                    <span><strong>@Model.Dashboard.TotalChunks</strong> chunks sẵn sàng cho AI/RAG</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card-custom">
            <div class="card-custom-header">
                <h5><i class="bi bi-clock-history me-2"></i>Tài liệu gần đây</h5>
                <a asp-page="/Documents/Index" class="btn btn-sm btn-outline-primary">
                    Xem tất cả <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="card-custom-body p-0">
                @if (!Model.Dashboard.RecentDocuments.Any())
                {
                    <div class="empty-state py-5">
                        <i class="bi bi-inbox"></i>
                        <p>Chưa có tài liệu nào</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-clean mb-0 align-middle">
                            <thead class="table-light text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 0.05em;">
                                <tr>
                                    <th>Tài liệu</th>
                                    <th>Loại</th>
                                    <th>Trạng thái</th>
                                    <th>Ngày upload</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in Model.Dashboard.RecentDocuments)
                                {
                                    <tr>
                                        <td>
                                            <a asp-page="/Documents/Detail" asp-route-id="@doc.DocumentID" class="doc-link">
                                                @doc.Title
                                            </a>
                                            <div class="doc-meta">@doc.SubjectName › @doc.ChapterName</div>
                                        </td>
                                        <td>
                                            <span class="badge @(doc.FileType == "pdf" ? "bg-danger" : doc.FileType == "docx" ? "bg-primary" : "bg-warning text-dark") rounded-pill">
                                                @doc.FileType.ToUpper()
                                            </span>
                                        </td>
                                        <td>
                                            @{
                                                var (cls, ico, txt) = doc.IndexStatus switch {
                                                    "Indexed"    => ("success", "check-circle-fill", "Indexed"),
                                                    "Processing" => ("info",    "hourglass-split",   "Processing"),
                                                    "Failed"     => ("danger",  "x-circle-fill",     "Failed"),
                                                    _            => ("warning", "clock",              "Pending")
                                                };
                                            }
                                            <span class="badge bg-@cls-subtle text-@cls border border-@cls-subtle">
                                                <i class="bi bi-@ico me-1"></i>@txt
                                            </span>
                                        </td>
                                        <td class="text-muted small">@doc.UploadedAt.ToString("dd/MM HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ctx = document.getElementById('monthlyUploadChart').getContext('2d');

            const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Dashboard.MonthlyUploads.Select(m => m.Label)));
            const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Dashboard.MonthlyUploads.Select(m => m.Count)));

            // Create gradient
            const gradient = ctx.createLinearGradient(0, 0, 0, 300);
            gradient.addColorStop(0, 'rgba(99, 102, 241, 0.8)');
            gradient.addColorStop(1, 'rgba(99, 102, 241, 0.1)');

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Số tài liệu',
                        data: data,
                        backgroundColor: gradient,
                        borderColor: 'rgba(99, 102, 241, 1)',
                        borderWidth: 2,
                        borderRadius: 8,
                        borderSkipped: false,
                        hoverBackgroundColor: 'rgba(99, 102, 241, 0.95)',
                        hoverBorderColor: 'rgba(79, 70, 229, 1)',
                        hoverBorderWidth: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(15, 23, 42, 0.9)',
                            titleColor: '#e2e8f0',
                            bodyColor: '#fff',
                            borderColor: 'rgba(99, 102, 241, 0.5)',
                            borderWidth: 1,
                            cornerRadius: 8,
                            padding: 12,
                            displayColors: false,
                            callbacks: {
                                title: function(items) { return 'Tháng ' + items[0].label; },
                                label: function(item) { return item.raw + ' tài liệu được upload'; }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                stepSize: 1,
                                color: '#94a3b8',
                                font: { size: 12, family: 'Inter' }
                            },
                            grid: {
                                color: 'rgba(148, 163, 184, 0.1)',
                                drawBorder: false
                            }
                        },
                        x: {
                            ticks: {
                                color: '#94a3b8',
                                font: { size: 11, family: 'Inter' }
                            },
                            grid: { display: false }
                        }
                    },
                    animation: {
                        duration: 1000,
                        easing: 'easeOutQuart'
                    }
                }
            });

            // Monthly Registration Chart (Admin only)
            const regCanvas = document.getElementById('monthlyRegistrationChart');
            if (regCanvas) {
                const regCtx = regCanvas.getContext('2d');
                const regLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Dashboard.MonthlyRegistrations.Select(m => m.Label)));
                const regData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Dashboard.MonthlyRegistrations.Select(m => m.Count)));

                const regGradient = regCtx.createLinearGradient(0, 0, 0, 300);
                regGradient.addColorStop(0, 'rgba(6, 182, 212, 0.8)');
                regGradient.addColorStop(1, 'rgba(6, 182, 212, 0.1)');

                new Chart(regCtx, {
                    type: 'bar',
                    data: {
                        labels: regLabels,
                        datasets: [{
                            label: 'Người dùng mới',
                            data: regData,
                            backgroundColor: regGradient,
                            borderColor: 'rgba(6, 182, 212, 1)',
                            borderWidth: 2,
                            borderRadius: 8,
                            borderSkipped: false,
                            hoverBackgroundColor: 'rgba(6, 182, 212, 0.95)',
                            hoverBorderColor: 'rgba(8, 145, 178, 1)',
                            hoverBorderWidth: 3
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: 'rgba(15, 23, 42, 0.9)',
                                titleColor: '#e2e8f0',
                                bodyColor: '#fff',
                                borderColor: 'rgba(6, 182, 212, 0.5)',
                                borderWidth: 1,
                                cornerRadius: 8,
                                padding: 12,
                                displayColors: false,
                                callbacks: {
                                    title: function(items) { return 'Tháng ' + items[0].label; },
                                    label: function(item) { return item.raw + ' tài khoản mới'; }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    stepSize: 1,
                                    color: '#94a3b8',
                                    font: { size: 12, family: 'Inter' }
                                },
                                grid: {
                                    color: 'rgba(148, 163, 184, 0.1)',
                                    drawBorder: false
                                }
                            },
                            x: {
                                ticks: {
                                    color: '#94a3b8',
                                    font: { size: 11, family: 'Inter' }
                                },
                                grid: { display: false }
                            }
                        },
                        animation: {
                            duration: 1000,
                            easing: 'easeOutQuart'
                        }
                    }
                });
            }

            // Listen to realtime updates to dynamically refresh Dashboard fragments
            document.addEventListener('realtimeUpdate', function(e) {
                console.log("Dashboard notified of realtime update:", e.detail);
                setTimeout(() => {
                    refreshPageFragments(["#dashboard-stats-panel", "#dashboard-status-docs-panel"])
                        .catch(err => console.error("Dashboard realtime refresh failed:", err));
                }, 1000);
            });
        });
    </script>
}
