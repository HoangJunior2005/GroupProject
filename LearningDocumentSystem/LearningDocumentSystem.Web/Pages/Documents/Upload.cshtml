@page
@model UploadModel
@{
    ViewData["Title"] = "Upload tài liệu";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-cloud-upload-fill me-2"></i>Upload tài liệu</h1>
        <p class="page-subtitle">Upload PDF, DOCX, PPTX — tự động chunking & embedding</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card-custom">
            <div class="card-custom-header">
                <h5><i class="bi bi-form me-2"></i>Thông tin tài liệu</h5>
            </div>
            <div class="card-custom-body">
                <form method="post" enctype="multipart/form-data" id="uploadForm">
                    @Html.AntiForgeryToken()

                    @if (ViewData["ConflictErrors"] is List<string> conflictErrors && conflictErrors.Any())
                    {
                        <div class="alert alert-danger border-0 shadow-sm d-flex align-items-start gap-3 p-4 mb-4 text-dark" style="border-radius: 12px; background-color: #fef2f2; border-left: 5px solid #ef4444 !important;">
                            <i class="bi bi-robot text-danger fs-3 mt-1"></i>
                            <div class="flex-grow-1">
                                <h5 class="alert-heading fw-bold text-danger mb-2"><i class="bi bi-exclamation-triangle-fill me-2"></i>AI Phát hiện Mâu thuẫn Kiến thức</h5>
                                <p class="mb-3 small text-secondary">Tài liệu của bạn không thể tải lên vì hệ thống AI phát hiện các thông tin mâu thuẫn trực tiếp với tài liệu hiện có trong môn học:</p>
                                <div class="d-flex flex-column gap-3">
                                    @foreach (var conflict in conflictErrors)
                                    {
                                        <div class="p-3 rounded border border-danger-subtle bg-white shadow-sm" style="border-radius: 8px;">
                                            <div class="d-flex align-items-center mb-2">
                                                <span class="badge bg-danger px-2.5 py-1.5 rounded-pill me-2 small">Mâu thuẫn</span>
                                                <strong class="text-danger small">Phát hiện sai lệch thông tin</strong>
                                            </div>
                                            <div class="text-secondary small mt-1 font-monospace" style="line-height: 1.6; white-space: pre-line; font-size: 0.875rem;">
                                                @conflict
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    else if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>
                    }

                    <!-- Title -->
                    <div class="mb-4">
                        <label asp-for="Input.Title" class="form-label fw-semibold">
                            <i class="bi bi-type me-1"></i> Tiêu đề tài liệu
                        </label>
                        <input asp-for="Input.Title" class="form-control form-control-lg"
                               placeholder="Nhập tiêu đề tài liệu..." id="docTitle"/>
                        <span asp-validation-for="Input.Title" class="text-danger small"></span>
                    </div>

                    <!-- Subject + Chapter -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-journal-bookmark me-1"></i> Môn học
                            </label>
                            <select asp-for="Input.SelectedSubjectId" class="form-select" id="subjectSelect" onchange="loadUploadChapters(this.value)">
                                <option value="">— Chọn môn học —</option>
                                @foreach (var s in Model.Input.Subjects)
                                {
                                    <option value="@s.SubjectID">
                                        [@s.SubjectCode] @s.SubjectName
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.ChapterId" class="form-label fw-semibold">
                                <i class="bi bi-collection me-1"></i> Chương
                            </label>
                            <select asp-for="Input.ChapterId" class="form-select" id="chapterSelect">
                                <option value="">— Chọn chương —</option>
                                @foreach (var c in Model.Input.Chapters)
                                {
                                    <option value="@c.ChapterID">
                                        Chương @c.ChapterNumber: @c.ChapterName
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="Input.ChapterId" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Drag & Drop Upload Zone -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-paperclip me-1"></i> File tài liệu
                        </label>
                        <div class="upload-zone" id="uploadZone">
                            <div class="upload-zone-inner" id="uploadZoneContent">
                                <div class="upload-icon">
                                    <i class="bi bi-cloud-upload"></i>
                                </div>
                                <p class="upload-text">Kéo thả file vào đây hoặc</p>
                                <label for="fileInput" class="btn btn-outline-primary">
                                    <i class="bi bi-folder2-open me-1"></i> Chọn file
                                </label>
                                <input type="file" asp-for="Input.File" id="fileInput"
                                       accept=".pdf,.docx,.pptx" class="d-none"
                                       onchange="handleFileSelect(this)"/>
                                <p class="upload-hint">PDF, DOCX, PPTX — tối đa 50MB</p>
                            </div>

                            <!-- File Preview (ẩn, hiện khi chọn file) -->
                            <div class="file-preview d-none" id="filePreview">
                                <div class="file-preview-icon" id="filePreviewIcon"></div>
                                <div class="file-preview-info">
                                    <div class="file-preview-name" id="filePreviewName"></div>
                                    <div class="file-preview-size" id="filePreviewSize"></div>
                                </div>
                                <button type="button" class="btn-remove-file" onclick="removeFile()">
                                    <i class="bi bi-x-circle-fill"></i>
                                </button>
                            </div>
                        </div>
                        <span asp-validation-for="Input.File" class="text-danger small"></span>
                    </div>

                    <!-- Submit -->
                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary btn-lg" id="btnUpload">
                            <span class="btn-text">Upload</span>
                            <span class="btn-loading d-none">
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                Đang xử lý...
                            </span>
                        </button>
                        <a asp-page="./Index" class="btn btn-outline-secondary btn-lg">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Sidebar Info -->
    <div class="col-lg-4">
        <div class="card-custom mb-4">
            <div class="card-custom-header">
                <h6><i class="bi bi-info-circle me-2"></i>Quy trình xử lý</h6>
            </div>
            <div class="card-custom-body">
                <div class="process-steps">
                    <div class="process-step active">
                        <div class="step-num">1</div>
                        <div class="step-info">
                            <div class="step-title">Upload file</div>
                            <div class="step-desc">Lưu vào /wwwroot/uploads</div>
                        </div>
                    </div>
                    <div class="process-step">
                        <div class="step-num">2</div>
                        <div class="step-info">
                            <div class="step-title">Đọc nội dung</div>
                            <div class="step-desc">Parse PDF/DOCX/PPTX</div>
                        </div>
                    </div>
                    <div class="process-step">
                        <div class="step-num">3</div>
                        <div class="step-info">
                            <div class="step-title">Chunking</div>
                            <div class="step-desc">Tách thành đoạn ~800 ký tự</div>
                        </div>
                    </div>
                    <div class="process-step">
                        <div class="step-num">4</div>
                        <div class="step-info">
                            <div class="step-title">Embedding</div>
                            <div class="step-desc">Sinh vector 512 chiều</div>
                        </div>
                    </div>
                    <div class="process-step">
                        <div class="step-num">5</div>
                        <div class="step-info">
                            <div class="step-title">Lưu DB</div>
                            <div class="step-desc">Sẵn sàng AI Search / RAG</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-custom">
            <div class="card-custom-header">
                <h6><i class="bi bi-shield-check me-2"></i>Định dạng hỗ trợ</h6>
            </div>
            <div class="card-custom-body">
                <div class="file-type-badge mb-2">
                    <i class="bi bi-file-earmark-pdf-fill text-danger fs-5 me-2"></i>
                    <span><strong>PDF</strong> — Tài liệu portable</span>
                </div>
                <div class="file-type-badge mb-2">
                    <i class="bi bi-file-earmark-word-fill text-primary fs-5 me-2"></i>
                    <span><strong>DOCX</strong> — Microsoft Word</span>
                </div>
                <div class="file-type-badge">
                    <i class="bi bi-file-earmark-ppt-fill text-warning fs-5 me-2"></i>
                    <span><strong>PPTX</strong> — PowerPoint</span>
                </div>
                <hr class="my-3"/>
                <div class="text-muted small">
                    <i class="bi bi-hdd me-1"></i> Kích thước tối đa: <strong>50 MB</strong>
                </div>
            </div>
        </div>

        <!-- Quick Links -->
        <div class="card-custom mt-3">
            <div class="card-custom-body">
                <div class="d-flex flex-column gap-2">
                    <a asp-page="/Documents/Index" class="btn btn-outline-secondary btn-sm w-100 text-start">
                        <i class="bi bi-list-ul me-2"></i>Danh sách tài liệu
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-page="/Admin/ChunkSettings" class="btn btn-sm w-100 text-start" style="background:linear-gradient(135deg,hsl(245,78%,62%),hsl(270,70%,58%));color:white;border:none;">
                            <i class="bi bi-sliders me-2"></i>⚙️ Cấu hình Chunking
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Drag & Drop
    const zone = document.getElementById('uploadZone');
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
    zone.addEventListener('drop', e => {
        e.preventDefault();
        zone.classList.remove('drag-over');
        const file = e.dataTransfer.files[0];
        if (file) {
            const dt = new DataTransfer();
            dt.items.add(file);
            document.getElementById('fileInput').files = dt.files;
            showFilePreview(file);
        }
    });

    function handleFileSelect(input) {
        if (input.files.length > 0) showFilePreview(input.files[0]);
    }

    function showFilePreview(file) {
        const ext = file.name.split('.').pop().toLowerCase();
        const icons = { pdf: 'bi-file-earmark-pdf-fill text-danger', docx: 'bi-file-earmark-word-fill text-primary', pptx: 'bi-file-earmark-ppt-fill text-warning' };
        document.getElementById('filePreviewIcon').innerHTML = `<i class="bi ${icons[ext] || 'bi-file-earmark'} fs-1"></i>`;
        document.getElementById('filePreviewName').textContent = file.name;
        document.getElementById('filePreviewSize').textContent = formatBytes(file.size);
        document.getElementById('uploadZoneContent').classList.add('d-none');
        document.getElementById('filePreview').classList.remove('d-none');

        // Auto-fill title from filename
        const titleInput = document.getElementById('docTitle');
        if (!titleInput.value) {
            titleInput.value = file.name.replace(/\.[^/.]+$/, "").replace(/[_-]/g, ' ');
        }
    }

    function removeFile() {
        document.getElementById('fileInput').value = '';
        document.getElementById('uploadZoneContent').classList.remove('d-none');
        document.getElementById('filePreview').classList.add('d-none');
    }

    function formatBytes(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1024*1024) return (bytes/1024).toFixed(1) + ' KB';
        return (bytes/(1024*1024)).toFixed(1) + ' MB';
    }

    // Load chapters by subject
    function loadUploadChapters(subjectId, selectedChapterId) {
        const select = document.getElementById('chapterSelect');
        select.innerHTML = '<option value="">Đang tải...</option>';
        if (!subjectId) { select.innerHTML = '<option value="">— Chọn chương —</option>'; return; }
        fetch('/Documents/Index?handler=GetChapters&subjectId=' + subjectId)
            .then(r => r.json())
            .then(data => {
                const val = selectedChapterId || select.value;
                select.innerHTML = '<option value="">— Chọn chương —</option>';
                data.forEach(c => {
                    const isSelected = String(c.chapterID) === String(val) ? "selected" : "";
                    select.innerHTML += `<option value="${c.chapterID}" ${isSelected}>Chương ${c.chapterNumber}: ${c.chapterName}</option>`;
                });
            });
    }

    function reloadSubjectsDropdown(selectId, currentSelectedValue) {
        const select = document.getElementById(selectId);
        if (!select) return;
        
        fetch('/Documents/Index?handler=GetSubjects')
            .then(r => r.json())
            .then(data => {
                const val = currentSelectedValue || select.value;
                const firstOptionText = select.options[0] ? select.options[0].text : "— Chọn môn học —";
                select.innerHTML = `<option value="">${firstOptionText}</option>`;
                data.forEach(s => {
                    const isSelected = String(s.subjectID) === String(val) ? "selected" : "";
                    select.innerHTML += `<option value="${s.subjectID}" ${isSelected}>[${s.subjectCode}] ${s.subjectName}</option>`;
                });
                
                // If onchange is defined, call it to reload chapters if selected subject has changed
                if (select.onchange) {
                    select.onchange();
                }
            })
            .catch(err => console.error("Error reloading subjects:", err));
    }

    // Realtime update listener to reload dropdowns dynamically
    document.addEventListener("realtimeUpdate", function(e) {
        const type = e.detail.messageType;
        if (type.startsWith("Subject")) {
            console.log("Subjects list updated. Refreshing dropdown in real-time...");
            const select = document.getElementById('subjectSelect');
            reloadSubjectsDropdown('subjectSelect', select.value);
        } else if (type.startsWith("Chapter")) {
            console.log("Chapters list updated. Refreshing dropdown in real-time...");
            const subjectId = document.getElementById('subjectSelect').value;
            if (subjectId) {
                const select = document.getElementById('chapterSelect');
                loadUploadChapters(subjectId, select.value);
            }
        }
    });

    // Upload button loading state
    document.getElementById('uploadForm').addEventListener('submit', function(e) {
        document.querySelector('#btnUpload .btn-text').classList.add('d-none');
        document.querySelector('#btnUpload .btn-loading').classList.remove('d-none');
        document.getElementById('btnUpload').disabled = true;
    });
</script>
}
