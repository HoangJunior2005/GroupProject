@page
@model LearningDocumentSystem.Web.Pages.Admin.BenchmarksModel
@{
    ViewData["Title"] = "Thống kê Hoạt động Học tập";
}

<style>
    :root {
        --bm-bg: #f8fafc; /* Nền xám nhạt sáng sủa */
        --bm-card: #ffffff; /* Card màu trắng */
        --bm-card-border: rgba(0,0,0,.08);
        --bm-accent: #6c5ce7;
        --bm-accent2: #00cec9;
        --bm-accent3: #fd79a8;
        --bm-accent4: #fdcb6e;
        --bm-text: #1e293b; /* Chữ màu xám đen */
        --bm-muted: #64748b; /* Chữ mờ màu xám trung tính */
        --bm-success: #00b894;
        --bm-radius: 16px;
        --bm-shadow: 0 4px 20px rgba(0,0,0,.05);
    }

    .bm-page {
        background: var(--bm-bg);
        min-height: 100vh;
        padding: 28px 24px 60px;
        color: var(--bm-text);
        font-family: 'Inter', sans-serif;
    }

    /* Header */
    .bm-header {
        display: flex; align-items: center; gap: 16px; margin-bottom: 36px;
    }
    .bm-header-icon {
        width: 56px; height: 56px; border-radius: 14px;
        background: linear-gradient(135deg, var(--bm-accent), var(--bm-accent2));
        display: flex; align-items: center; justify-content: center;
        font-size: 26px; color: #fff;
        box-shadow: 0 4px 20px rgba(108,92,231,.4);
        flex-shrink: 0;
    }
    .bm-header h1 {
        font-size: 1.75rem; font-weight: 800; margin: 0;
        background: linear-gradient(135deg, #1e293b 0%, var(--bm-accent) 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .bm-header p { margin: 4px 0 0; color: var(--bm-muted); font-size: .88rem; }

    /* Section title */
    .bm-section-title {
        font-size: 1.05rem; font-weight: 700; margin: 0 0 18px;
        display: flex; align-items: center; gap: 10px;
    }
    .bm-section-title i { font-size: 1.15rem; color: var(--bm-accent); }
    .bm-section-title::after {
        content: ''; flex: 1; height: 1px;
        background: linear-gradient(90deg, var(--bm-card-border), transparent);
    }

    /* KPI grid */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-bottom: 32px;
    }
    .kpi-card {
        background: var(--bm-card);
        border: 1px solid var(--bm-card-border);
        border-radius: var(--bm-radius);
        padding: 24px;
        box-shadow: var(--bm-shadow);
        position: relative; overflow: hidden;
        transition: transform .25s, box-shadow .25s;
    }
    .kpi-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(0,0,0,.45); }
    .kpi-card::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
        border-radius: var(--bm-radius) var(--bm-radius) 0 0;
    }
    .kpi-card:nth-child(1)::before { background: linear-gradient(90deg, #6c5ce7, #00cec9); }
    .kpi-card:nth-child(2)::before { background: linear-gradient(90deg, #00cec9, #0984e3); }
    .kpi-card:nth-child(3)::before { background: linear-gradient(90deg, #fd79a8, #fdcb6e); }
    .kpi-card:nth-child(4)::before { background: linear-gradient(90deg, #fdcb6e, #00b894); }

    .kpi-icon {
        width: 44px; height: 44px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; margin-bottom: 14px;
    }
    .kpi-value { font-size: 2rem; font-weight: 800; line-height: 1.1; margin-bottom: 4px; }
    .kpi-label { font-size: .82rem; color: var(--bm-muted); font-weight: 500; }
    .kpi-sub { font-size: .75rem; color: var(--bm-muted); margin-top: 8px; opacity: .8; }

    /* Chart grid */
    .chart-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    .chart-card {
        background: var(--bm-card);
        border: 1px solid var(--bm-card-border);
        border-radius: var(--bm-radius);
        padding: 24px;
        box-shadow: var(--bm-shadow);
    }
    .chart-card.full-width { grid-column: 1 / -1; }
    .chart-card h5 { font-size: .95rem; font-weight: 700; margin-bottom: 4px; }
    .chart-card .chart-desc { font-size: .78rem; color: var(--bm-muted); margin-bottom: 18px; }
    .chart-wrapper { position: relative; width: 100%; }
    .chart-wrapper canvas { width: 100% !important; }

    /* Rating Summary Cards */
    .rating-summary-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }
    .rating-summary-card {
        border-radius: var(--bm-radius);
        padding: 20px 24px;
        display: flex;
        align-items: center;
        gap: 18px;
        box-shadow: var(--bm-shadow);
        position: relative;
        overflow: hidden;
        transition: transform .25s, box-shadow .25s;
    }
    .rating-summary-card:hover { transform: translateY(-3px); box-shadow: 0 10px 36px rgba(0,0,0,.5); }
    .rating-summary-card.loved {
        background: linear-gradient(135deg, rgba(0,184,148,0.18), rgba(0,184,148,0.06));
        border: 1px solid rgba(0,184,148,0.3);
    }
    .rating-summary-card.hated {
        background: linear-gradient(135deg, rgba(225,112,85,0.18), rgba(225,112,85,0.06));
        border: 1px solid rgba(225,112,85,0.3);
    }
    .rating-summary-card .rs-icon {
        font-size: 2.6rem;
        line-height: 1;
        flex-shrink: 0;
        filter: drop-shadow(0 2px 8px rgba(0,0,0,.3));
    }
    .rating-summary-card .rs-content { flex: 1; min-width: 0; }
    .rating-summary-card .rs-badge {
        font-size: .72rem;
        font-weight: 600;
        letter-spacing: .06em;
        text-transform: uppercase;
        padding: 3px 10px;
        border-radius: 20px;
        display: inline-block;
        margin-bottom: 6px;
    }
    .loved .rs-badge { background: rgba(0,184,148,0.2); color: #00b894; }
    .hated .rs-badge { background: rgba(225,112,85,0.2); color: #e17055; }
    .rating-summary-card .rs-model {
        font-size: 1.45rem;
        font-weight: 800;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .loved .rs-model { color: #00b894; }
    .hated .rs-model { color: #e17055; }
    .rating-summary-card .rs-stat {
        font-size: .8rem;
        color: var(--bm-muted);
        margin-top: 4px;
    }
    .rating-summary-card .rs-glow {
        position: absolute; width: 120px; height: 120px;
        border-radius: 50%; opacity: .12; right: -20px; top: -20px;
    }
    .loved .rs-glow { background: #00b894; }
    .hated .rs-glow { background: #e17055; }

    @@media (max-width: 992px) { .chart-grid { grid-template-columns: 1fr; } }
    @@media (max-width: 768px) { .kpi-grid { grid-template-columns: 1fr 1fr; } .rating-summary-grid { grid-template-columns: 1fr; } }
    @@media (max-width: 480px) { .kpi-grid { grid-template-columns: 1fr; } }
</style>

<div class="bm-page">

    @* ── Header ── *@
    <div class="bm-header">
        <div class="bm-header-icon"><i class="bi bi-bar-chart-line-fill"></i></div>
        <div>
            <h1>Thống kê Hoạt động Học tập</h1>
            <p>Tổng quan mức độ sử dụng hệ thống, phân bổ model AI và xu hướng tiêu thụ tài nguyên trong toàn trường</p>
        </div>
    </div>

    @* ── KPI Cards ── *@
    <div class="bm-section-title"><i class="bi bi-activity"></i> Tổng quan nhanh</div>
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-icon" style="background:rgba(108,92,231,.15);color:#6c5ce7">
                <i class="bi bi-people-fill"></i>
            </div>
            <div class="kpi-value" id="kpiActiveStudents">@Model.Dashboard.TotalActiveStudents.ToString("N0")</div>
            <div class="kpi-label">Sinh viên đang hoạt động</div>
            <div class="kpi-sub">Đã thực hiện ít nhất 1 câu hỏi</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon" style="background:rgba(0,206,201,.15);color:#00cec9">
                <i class="bi bi-collection-fill"></i>
            </div>
            <div class="kpi-value" id="kpiTotalSessions">@Model.Dashboard.TotalSessions.ToString("N0")</div>
            <div class="kpi-label">Tổng phiên hội thoại</div>
            <div class="kpi-sub">Lịch sử phiên chat đã tạo</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon" style="background:rgba(253,121,168,.15);color:#fd79a8">
                <i class="bi bi-chat-left-text-fill"></i>
            </div>
            <div class="kpi-value" id="kpiTotalQueries">@Model.Dashboard.TotalQueries.ToString("N0")</div>
            <div class="kpi-label">Tổng số truy vấn</div>
            <div class="kpi-sub">Câu hỏi đã được gửi đi</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon" style="background:rgba(253,203,110,.15);color:#fdcb6e">
                <i class="bi bi-stars"></i>
            </div>
            <div class="kpi-value" id="kpiMostUsedModel" style="font-size:1.4rem">@Model.Dashboard.MostUsedModel</div>
            <div class="kpi-label">Model AI phổ biến nhất</div>
            <div class="kpi-sub">Được sinh viên sử dụng nhiều nhất</div>
        </div>
    </div>

    @* ── Charts ── *@
    <div class="bm-section-title"><i class="bi bi-graph-up-arrow"></i> Biểu đồ phân tích</div>
    <div class="chart-grid">

        @* C1. Model Usage Donut *@
        <div class="chart-card">
            <h5><i class="bi bi-pie-chart-fill" style="color:var(--bm-accent)"></i> Tần suất sử dụng Model AI</h5>
            <div class="chart-desc">Tỷ lệ % mỗi LLM được sinh viên sử dụng trong toàn hệ thống</div>
            <div class="chart-wrapper" style="max-height:300px;display:flex;align-items:center;justify-content:center">
                <canvas id="chartModelUsageDonut"></canvas>
            </div>
        </div>

        @* C1.5. Unique Students Usage (Horizontal Bar) *@
        <div class="chart-card">
            <h5><i class="bi bi-people-fill" style="color:var(--bm-accent2)"></i> Mức độ phổ biến (Theo sinh viên)</h5>
            <div class="chart-desc">Số lượng sinh viên thực tế đã tương tác với mỗi Model</div>
            <div class="chart-wrapper" style="max-height:300px"><canvas id="chartStudentUsageBar"></canvas></div>
        </div>

        @* C2. Model Ratings Grouped Column — ApexCharts *@
        <div class="chart-card full-width">
            <h5><i class="bi bi-bar-chart-fill" style="color:#fd79a8"></i> Mức độ hài lòng (Rating) Model AI</h5>
            <div class="chart-desc">So sánh trực tiếp lượt 👍 Hài lòng vs 👎 Không hài lòng theo từng Model — kèm tổng hợp yêu thích nhất</div>

            @* Rating Summary Cards *@
            <div class="rating-summary-grid" id="ratingSummaryGrid" style="display:none">
                <div class="rating-summary-card loved">
                    <div class="rs-glow"></div>
                    <div class="rs-icon">🏆</div>
                    <div class="rs-content">
                        <div class="rs-badge">👍 Được yêu thích nhất</div>
                        <div class="rs-model" id="rsLovedModel">—</div>
                        <div class="rs-stat" id="rsLovedStat"></div>
                    </div>
                </div>
                <div class="rating-summary-card hated">
                    <div class="rs-glow"></div>
                    <div class="rs-icon">📉</div>
                    <div class="rs-content">
                        <div class="rs-badge">👎 Bị đánh giá xấu nhiều nhất</div>
                        <div class="rs-model" id="rsHatedModel">—</div>
                        <div class="rs-stat" id="rsHatedStat"></div>
                    </div>
                </div>
            </div>

            <div class="chart-wrapper" style="max-height:340px"><canvas id="chartModelRatings"></canvas></div>
        </div>

        @* C3. Monthly Token Usage Line *@
        <div class="chart-card full-width">
            <h5><i class="bi bi-coin" style="color:#fdcb6e"></i> Lượng Token tiêu thụ theo tháng</h5>
            <div class="chart-desc">Tổng token (Prompt + Completion) mỗi tháng theo từng Model — 6 tháng gần nhất</div>
            <div class="chart-wrapper" style="max-height:360px"><canvas id="chartMonthlyToken"></canvas></div>
        </div>

        @* C4. Monthly Latency Trend Line *@
        <div class="chart-card full-width">
            <h5><i class="bi bi-speedometer2" style="color:#00cec9"></i> Tốc độ phản hồi trung bình theo tháng</h5>
            <div class="chart-desc">Latency (ms) của từng Model AI qua từng tháng — 6 tháng gần nhất</div>
            <div class="chart-wrapper" style="max-height:340px"><canvas id="chartMonthlyLatency"></canvas></div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <!-- Add SignalR client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        Chart.defaults.color = '#64748b'; /* Màu chữ mặc định sáng */
        Chart.defaults.font.family = "'Inter', sans-serif";
        Chart.defaults.font.size = 12;
        Chart.defaults.plugins.legend.labels.usePointStyle = true;

        const COLORS = {
            accent: '#6c5ce7', accent2: '#00cec9', accent3: '#fd79a8',
            accent4: '#fdcb6e', success: '#00b894'
        };

        // Initialize empty chart variables
        let chartModelUsage = null;
        let chartStudentUsage = null;
        let chartModelRatings = null;
        let chartMonthlyToken = null;
        let chartMonthlyLatency = null;

        // Render functions
        function renderCharts(data) {
            // ── C1. Model Usage Donut ──
            const modelUsageLabels = data.modelUsage.map(m => m.providerName);
            const modelUsageCounts = data.modelUsage.map(m => m.totalQueries);
            const modelUsagePercents = data.modelUsage.map(m => m.usagePercent);
            const modelUniqueStudents = data.modelUsage.map(m => m.uniqueStudents);

            if (modelUsageLabels.length > 0 && modelUsageCounts.some(v => v > 0)) {
                // ── Biểu đồ Donut (Tần suất sử dụng) ──
                if (chartModelUsage) chartModelUsage.destroy();
                chartModelUsage = new Chart(document.getElementById('chartModelUsageDonut'), {
                    type: 'doughnut',
                    data: {
                        labels: modelUsageLabels,
                        datasets: [{
                            data: modelUsageCounts,
                            backgroundColor: ['rgba(108,92,231,0.85)', 'rgba(0,206,201,0.85)', 'rgba(253,121,168,0.85)', 'rgba(253,203,110,0.85)', 'rgba(0,184,148,0.85)'],
                            borderColor: '#ffffff', borderWidth: 2, hoverOffset: 8
                        }]
                    },
                    options: {
                        responsive: true, maintainAspectRatio: false, cutout: '65%',
                        plugins: {
                            legend: { position: 'right', labels: { color: '#64748b', font: { weight: 'bold' } } },
                            tooltip: { 
                                backgroundColor: '#ffffff', titleColor: '#1e293b', bodyColor: '#64748b', borderColor: 'rgba(0,0,0,.1)', borderWidth: 1,
                                callbacks: { label: ctx => {
                                    const i = ctx.dataIndex;
                                    return [` ${ctx.label}: ${modelUsageCounts[i]} queries (${modelUsagePercents[i]}%)`];
                                }}
                            }
                        }
                    }
                });

                // ── Biểu đồ Cột ngang (Sinh viên sử dụng) ──
                if (chartStudentUsage) chartStudentUsage.destroy();
                chartStudentUsage = new Chart(document.getElementById('chartStudentUsageBar'), {
                    type: 'bar',
                    data: {
                        labels: modelUsageLabels,
                        datasets: [{
                            label: 'Số sinh viên',
                            data: modelUniqueStudents,
                            backgroundColor: ['rgba(108,92,231,0.85)', 'rgba(0,206,201,0.85)', 'rgba(253,121,168,0.85)', 'rgba(253,203,110,0.85)', 'rgba(0,184,148,0.85)'],
                            borderRadius: 4,
                            barPercentage: 0.6
                        }]
                    },
                    options: {
                        indexAxis: 'y', // Chuyển thành cột ngang
                        responsive: true, maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: { 
                                backgroundColor: '#ffffff', titleColor: '#1e293b', bodyColor: '#64748b', borderColor: 'rgba(0,0,0,.1)', borderWidth: 1,
                                callbacks: { label: ctx => ` ${ctx.raw} sinh viên` }
                            }
                        },
                        scales: {
                            x: { 
                                title: { display: true, text: 'Số lượng sinh viên', color: '#64748b' },
                                grid: { color: 'rgba(0,0,0,.05)', borderDash: [4, 4] },
                                ticks: { color: '#64748b', stepSize: 1 }
                            },
                            y: { 
                                grid: { display: false },
                                ticks: { color: '#64748b', font: { weight: 'bold' } }
                            }
                        }
                    }
                });
            }

            // ── C2. Model Ratings Grouped Column (Chart.js) ──
            const ratingLabels   = data.modelRatings.map(r => r.providerName);
            const ratingUp       = data.modelRatings.map(r => r.thumbsUp);
            const ratingDown     = data.modelRatings.map(r => r.thumbsDown);
            const ratingPercents = data.modelRatings.map(r => r.ratingPercent);

            if (ratingLabels.length > 0) {
                // ── Summary Cards ──
                const maxUpIdx   = ratingUp.indexOf(Math.max(...ratingUp));
                const maxDownIdx = ratingDown.indexOf(Math.max(...ratingDown));
                document.getElementById('rsLovedModel').textContent  = ratingLabels[maxUpIdx]   || '—';
                document.getElementById('rsHatedModel').textContent  = ratingLabels[maxDownIdx] || '—';
                document.getElementById('rsLovedStat').textContent   = `${ratingUp[maxUpIdx]} lượt 👍  •  Tỷ lệ hài lòng: ${ratingPercents[maxUpIdx]}%`;
                document.getElementById('rsHatedStat').textContent   = `${ratingDown[maxDownIdx]} lượt 👎  •  Tỷ lệ không hài lòng: ${(100 - ratingPercents[maxDownIdx]).toFixed(1)}%`;
                document.getElementById('ratingSummaryGrid').style.display = 'grid';

                // ── Grouped Column Chart.js ──
                if (chartModelRatings) chartModelRatings.destroy();
                chartModelRatings = new Chart(document.getElementById('chartModelRatings'), {
                    type: 'bar',
                    data: {
                        labels: ratingLabels,
                        datasets: [
                            { 
                                label: '👍 Hài lòng', 
                                data: ratingUp, 
                                backgroundColor: '#2563eb', /* Màu xanh blue giống hệt biểu đồ độ trễ */
                                borderWidth: 0, 
                                borderRadius: 0, /* Cột vuông vức */
                                barPercentage: 0.9,
                                categoryPercentage: 0.8
                            },
                            { 
                                label: '👎 Không hài lòng', 
                                data: ratingDown, 
                                backgroundColor: '#ef4444', /* Màu đỏ phẳng */
                                borderWidth: 0, 
                                borderRadius: 0, /* Cột vuông vức */
                                barPercentage: 0.9,
                                categoryPercentage: 0.8
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { 
                            legend: { position: 'top', labels: { color: '#64748b', font: { weight: 'bold' } } },
                            tooltip: { 
                                backgroundColor: '#ffffff',
                                titleColor: '#1e293b',
                                bodyColor: '#64748b',
                                borderColor: 'rgba(0,0,0,.1)',
                                borderWidth: 1,
                                callbacks: { 
                                    afterBody: items => {
                                        const idx = items[0].dataIndex;
                                        const up = ratingUp[idx];
                                        const down = ratingDown[idx];
                                        const total = up + down;
                                        const pct = total > 0 ? ((up / total) * 100).toFixed(1) : 0;
                                        return `\nTỷ lệ hài lòng: ${pct}%`;
                                    } 
                                } 
                            }
                        },
                        scales: { 
                            x: { 
                                grid: { display: false },
                                ticks: { color: '#64748b', font: { size: 13, weight: 'bold' } }
                            }, 
                            y: { 
                                title: { display: true, text: 'Số lượt đánh giá', color: '#64748b' },
                                grid: { color: 'rgba(0,0,0,.05)', borderDash: [4, 4] },
                                ticks: { color: '#64748b', stepSize: 1, precision: 0 }
                            } 
                        }
                    }
                });
            }

            // ── C3. Monthly Token Usage Line ──
            const monthlyTokenRaw = data.monthlyTokens;
            const tokenMonths    = [...new Set(monthlyTokenRaw.map(d => d.monthLabel))];
            const tokenProviders = [...new Set(monthlyTokenRaw.map(d => d.providerName))];
            const tokenLineColor = { 'Gemini': COLORS.accent, 'OpenAI': COLORS.accent2, 'Groq': COLORS.accent3 };
            const tokenFill      = { 'Gemini': 'rgba(108,92,231,0.12)', 'OpenAI': 'rgba(0,206,201,0.12)', 'Groq': 'rgba(253,121,168,0.12)' };

            if (chartMonthlyToken) chartMonthlyToken.destroy();
            chartMonthlyToken = new Chart(document.getElementById('chartMonthlyToken'), {
                type: 'line',
                data: {
                    labels: tokenMonths,
                    datasets: tokenProviders.map(p => {
                        const pd = monthlyTokenRaw.filter(d => d.providerName === p);
                        return {
                            label: p,
                            data: tokenMonths.map(m => { const e = pd.find(d => d.monthLabel === m); return e ? e.totalTokens : 0; }),
                            borderColor: tokenLineColor[p] || COLORS.accent4,
                            backgroundColor: tokenFill[p] || 'rgba(253,203,110,0.1)',
                            borderWidth: 2.5, pointRadius: 5, pointHoverRadius: 7, tension: 0.35, fill: true
                        };
                    })
                },
                options: {
                    responsive: true, interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { position: 'top' },
                        tooltip: { 
                            backgroundColor: '#ffffff', titleColor: '#1e293b', bodyColor: '#64748b', borderColor: 'rgba(0,0,0,.1)', borderWidth: 1,
                            callbacks: { afterBody: items => [`Tổng: ${items.reduce((s, i) => s + i.parsed.y, 0).toLocaleString()} tokens`] } 
                        }
                    },
                    scales: {
                        y: { beginAtZero: true, title: { display: true, text: 'Tổng tokens' }, grid: { color: 'rgba(0,0,0,.05)' }, ticks: { callback: v => v >= 1000 ? (v/1000).toFixed(0) + 'K' : v } },
                        x: { grid: { display: false } }
                    }
                }
            });

            // ── C4. Monthly Latency Chart (Bar) ──
            const monthlyLatencyRaw = data.monthlyLatency;
            const latencyMonths      = [...new Set(monthlyLatencyRaw.map(d => d.monthLabel))];
            const latencyProviders   = [...new Set(monthlyLatencyRaw.map(d => d.providerName))];
            const latencyLineColor   = { 'Gemini': COLORS.accent, 'OpenAI': COLORS.accent2, 'Groq': COLORS.accent3 };
            const latencyBgColor     = { 'Gemini': 'rgba(108,92,231,0.85)', 'OpenAI': 'rgba(0,206,201,0.85)', 'Groq': 'rgba(253,121,168,0.85)' };

            if (chartMonthlyLatency) chartMonthlyLatency.destroy();
            chartMonthlyLatency = new Chart(document.getElementById('chartMonthlyLatency'), {
                type: 'bar', /* Đổi từ line sang bar */
                data: {
                    labels: latencyMonths,
                    datasets: latencyProviders.map(p => {
                        const pd = monthlyLatencyRaw.filter(d => d.providerName === p);
                        return {
                            label: p,
                            data: latencyMonths.map(m => { const e = pd.find(d => d.monthLabel === m); return e && e.avgLatencyMs > 0 ? e.avgLatencyMs : null; }),
                            backgroundColor: latencyBgColor[p] || 'rgba(253,203,110,0.85)',
                            borderColor: latencyLineColor[p] || COLORS.accent4,
                            borderWidth: 1, 
                            borderRadius: 4,
                            barPercentage: 0.8,
                            categoryPercentage: 0.7
                        };
                    })
                },
                options: {
                    responsive: true, 
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: { 
                        legend: { position: 'top', labels: { color: '#64748b', font: { weight: 'bold' } } },
                        tooltip: {
                            backgroundColor: '#ffffff',
                            titleColor: '#1e293b',
                            bodyColor: '#64748b',
                            borderColor: 'rgba(0,0,0,.1)',
                            borderWidth: 1
                        }
                    },
                    scales: {
                        y: { 
                            beginAtZero: true, 
                            title: { display: true, text: 'Độ trễ trung bình (ms)', color: '#64748b' }, 
                            grid: { color: 'rgba(0,0,0,.05)', borderDash: [4, 4] },
                            ticks: { color: '#64748b' }
                        },
                        x: { 
                            grid: { display: false },
                            ticks: { color: '#64748b', font: { weight: 'bold' } }
                        }
                    }
                }
            });
        }

        // Initial render with Razor model data
        const initialData = @Html.Raw(Json.Serialize(Model.Dashboard));
        renderCharts(initialData);

        // SignalR Real-time Updates
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveNotification", function (messageType, payload) {
            if (messageType === "DashboardUpdated") {
                // Flash animation for header icon to show update
                const icon = document.querySelector('.bm-header-icon');
                if (icon) {
                    icon.style.transform = 'scale(1.1)';
                    setTimeout(() => icon.style.transform = 'scale(1)', 200);
                }

                // Fetch new data
                fetch('?handler=DashboardData')
                    .then(response => response.json())
                    .then(result => {
                        if (result.success && result.data) {
                            // Update KPIs
                            document.getElementById('kpiActiveStudents').innerText = result.data.totalActiveStudents.toLocaleString();
                            document.getElementById('kpiTotalSessions').innerText = result.data.totalSessions.toLocaleString();
                            document.getElementById('kpiTotalQueries').innerText = result.data.totalQueries.toLocaleString();
                            document.getElementById('kpiMostUsedModel').innerText = result.data.mostUsedModel;

                            // Re-render Charts
                            renderCharts(result.data);
                        }
                    })
                    .catch(error => console.error('Error fetching real-time dashboard data:', error));
            }
        });

        connection.start()
            .then(() => console.log("Analytics real-time connection established."))
            .catch(err => console.error("SignalR connection error: ", err.toString()));
    </script>
}
