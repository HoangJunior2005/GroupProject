@page
@model LearningDocumentSystem.Web.Pages.Admin.BenchmarksModel
@{
    ViewData["Title"] = "Benchmark Dashboard";
}

@* ===== INLINE STYLES ===== *@
<style>
    /* ── Design Tokens ── */
    :root {
        --bm-bg: #0f1117;
        --bm-card: #1a1d2e;
        --bm-card-border: rgba(255,255,255,.06);
        --bm-accent: #6c5ce7;
        --bm-accent2: #00cec9;
        --bm-accent3: #fd79a8;
        --bm-accent4: #fdcb6e;
        --bm-text: #e2e8f0;
        --bm-muted: #94a3b8;
        --bm-success: #00b894;
        --bm-danger: #e17055;
        --bm-radius: 16px;
        --bm-shadow: 0 4px 24px rgba(0,0,0,.35);
    }

    .benchmark-page {
        background: var(--bm-bg);
        min-height: 100vh;
        padding: 28px 24px 60px;
        color: var(--bm-text);
        font-family: 'Inter', sans-serif;
    }

    /* ── Header ── */
    .bm-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 32px;
    }
    .bm-header-icon {
        width: 56px; height: 56px;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--bm-accent), var(--bm-accent2));
        display: flex; align-items: center; justify-content: center;
        font-size: 26px; color: #fff;
        box-shadow: 0 4px 20px rgba(108,92,231,.4);
    }
    .bm-header h1 {
        font-size: 1.75rem; font-weight: 800;
        background: linear-gradient(135deg, #fff 0%, var(--bm-accent2) 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        margin: 0;
    }
    .bm-header p { margin: 2px 0 0; color: var(--bm-muted); font-size: .88rem; }

    /* ── Section Title ── */
    .bm-section-title {
        font-size: 1.1rem; font-weight: 700; margin: 36px 0 18px;
        display: flex; align-items: center; gap: 10px;
    }
    .bm-section-title i { font-size: 1.2rem; color: var(--bm-accent); }
    .bm-section-title::after {
        content: ''; flex: 1; height: 1px;
        background: linear-gradient(90deg, var(--bm-card-border), transparent);
    }

    /* ── KPI Cards ── */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
        margin-bottom: 10px;
    }
    .kpi-card {
        background: var(--bm-card);
        border: 1px solid var(--bm-card-border);
        border-radius: var(--bm-radius);
        padding: 24px;
        box-shadow: var(--bm-shadow);
        position: relative; overflow: hidden;
        transition: transform .25s, box-shadow .25s;
    }
    .kpi-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 32px rgba(0,0,0,.45);
    }
    .kpi-card::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
        border-radius: var(--bm-radius) var(--bm-radius) 0 0;
    }
    .kpi-card:nth-child(1)::before { background: linear-gradient(90deg, var(--bm-accent), var(--bm-accent2)); }
    .kpi-card:nth-child(2)::before { background: linear-gradient(90deg, var(--bm-accent2), #0984e3); }
    .kpi-card:nth-child(3)::before { background: linear-gradient(90deg, var(--bm-accent3), var(--bm-accent4)); }
    .kpi-card:nth-child(4)::before { background: linear-gradient(90deg, var(--bm-accent4), var(--bm-success)); }

    .kpi-icon {
        width: 44px; height: 44px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; margin-bottom: 14px;
    }
    .kpi-card:nth-child(1) .kpi-icon { background: rgba(108,92,231,.15); color: var(--bm-accent); }
    .kpi-card:nth-child(2) .kpi-icon { background: rgba(0,206,201,.15); color: var(--bm-accent2); }
    .kpi-card:nth-child(3) .kpi-icon { background: rgba(253,121,168,.15); color: var(--bm-accent3); }
    .kpi-card:nth-child(4) .kpi-icon { background: rgba(253,203,110,.15); color: var(--bm-accent4); }

    .kpi-value {
        font-size: 2rem; font-weight: 800; line-height: 1.1;
        margin-bottom: 4px;
    }
    .kpi-label { font-size: .82rem; color: var(--bm-muted); font-weight: 500; }
    .kpi-sub { font-size: .75rem; color: var(--bm-muted); margin-top: 8px; opacity: .8; }

    /* ── Chart Cards ── */
    .chart-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    .chart-card {
        background: var(--bm-card);
        border: 1px solid var(--bm-card-border);
        border-radius: var(--bm-radius);
        padding: 24px;
        box-shadow: var(--bm-shadow);
    }
    .chart-card.full-width { grid-column: 1 / -1; }
    .chart-card h5 {
        font-size: .95rem; font-weight: 700; margin-bottom: 4px;
    }
    .chart-card .chart-desc {
        font-size: .78rem; color: var(--bm-muted); margin-bottom: 18px;
    }
    .chart-wrapper { position: relative; width: 100%; }
    .chart-wrapper canvas { width: 100% !important; }

    /* ── Playground ── */
    .playground-card {
        background: var(--bm-card);
        border: 1px solid var(--bm-card-border);
        border-radius: var(--bm-radius);
        padding: 28px;
        box-shadow: var(--bm-shadow);
    }
    .pg-input-group {
        display: flex; gap: 12px; flex-wrap: wrap; align-items: flex-end;
        margin-bottom: 20px;
    }
    .pg-input-group .form-group { flex: 1; min-width: 180px; }
    .pg-input-group label {
        font-size: .8rem; font-weight: 600; color: var(--bm-muted);
        margin-bottom: 6px; display: block;
    }
    .pg-input-group input,
    .pg-input-group select {
        width: 100%; padding: 10px 14px;
        background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1);
        border-radius: 10px; color: var(--bm-text); font-size: .88rem;
        transition: border-color .2s;
    }
    .pg-input-group input:focus,
    .pg-input-group select:focus {
        border-color: var(--bm-accent); outline: none;
        box-shadow: 0 0 0 3px rgba(108,92,231,.2);
    }
    .pg-input-group select option { background: #1a1d2e; color: #e2e8f0; }

    .btn-benchmark {
        padding: 10px 28px;
        background: linear-gradient(135deg, var(--bm-accent), var(--bm-accent2));
        color: #fff; border: none; border-radius: 10px;
        font-weight: 700; font-size: .9rem;
        cursor: pointer; transition: transform .2s, box-shadow .2s;
        white-space: nowrap;
        display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-benchmark:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(108,92,231,.4);
    }
    .btn-benchmark:disabled {
        opacity: .6; cursor: not-allowed; transform: none;
    }
    .btn-benchmark .spinner-border {
        width: 16px; height: 16px; border-width: 2px;
    }

    /* Playground Results */
    .pg-results-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 16px;
    }
    .pg-model-card {
        background: rgba(255,255,255,.03);
        border: 1px solid var(--bm-card-border);
        border-radius: 12px;
        padding: 18px;
        transition: border-color .3s;
    }
    .pg-model-card:hover { border-color: var(--bm-accent); }
    .pg-model-card .model-name {
        font-weight: 700; font-size: .95rem; margin-bottom: 8px;
        display: flex; align-items: center; gap: 8px;
    }
    .pg-model-card .model-name .dot {
        width: 8px; height: 8px; border-radius: 50%;
        display: inline-block;
    }
    .pg-model-card:nth-child(1) .dot { background: var(--bm-accent); }
    .pg-model-card:nth-child(2) .dot { background: var(--bm-accent2); }
    .pg-model-card:nth-child(3) .dot { background: var(--bm-accent3); }
    .pg-model-card:nth-child(4) .dot { background: var(--bm-accent4); }
    .pg-model-card:nth-child(5) .dot { background: var(--bm-success); }

    .pg-timing {
        display: flex; gap: 12px; margin-bottom: 14px; flex-wrap: wrap;
    }
    .pg-timing .badge-timing {
        padding: 4px 10px; border-radius: 6px;
        font-size: .73rem; font-weight: 600;
        background: rgba(108,92,231,.15); color: var(--bm-accent);
    }
    .pg-timing .badge-timing.search {
        background: rgba(0,206,201,.15); color: var(--bm-accent2);
    }
    .pg-timing .badge-timing.total {
        background: rgba(253,203,110,.15); color: var(--bm-accent4);
    }

    .pg-chunk-item {
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.05);
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 8px;
        font-size: .82rem;
    }
    .pg-chunk-item .chunk-header {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 6px;
    }
    .pg-chunk-item .chunk-title {
        font-weight: 600; font-size: .8rem;
        color: var(--bm-accent2);
    }
    .pg-chunk-item .cosine-badge {
        padding: 2px 8px; border-radius: 4px;
        font-size: .72rem; font-weight: 700;
        background: rgba(0,184,148,.15); color: var(--bm-success);
    }
    .pg-chunk-item .chunk-text {
        color: var(--bm-muted); font-size: .78rem; line-height: 1.5;
    }

    .pg-empty {
        text-align: center; padding: 40px; color: var(--bm-muted);
        font-size: .9rem;
    }
    .pg-empty i { font-size: 2.5rem; display: block; margin-bottom: 12px; opacity: .4; }

    /* ── Responsive ── */
    @@media (max-width: 992px) {
        .chart-grid { grid-template-columns: 1fr; }
        .pg-results-grid { grid-template-columns: 1fr; }
    }
    @@media (max-width: 768px) {
        .kpi-grid { grid-template-columns: 1fr 1fr; }
        .pg-input-group { flex-direction: column; }
    }
    @@media (max-width: 480px) {
        .kpi-grid { grid-template-columns: 1fr; }
    }

    /* Simulated data badge */
    .sim-badge {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 2px 8px; border-radius: 4px;
        font-size: .68rem; font-weight: 600;
        background: rgba(253,203,110,.12); color: var(--bm-accent4);
        margin-left: 8px;
    }
</style>

<div class="benchmark-page">

    @* ===== HEADER ===== *@
    <div class="bm-header">
        <div class="bm-header-icon"><i class="bi bi-graph-up"></i></div>
        <div>
            <h1>Benchmark Dashboard</h1>
            <p>Theo dõi & So sánh hiệu suất giữa các mô hình nhúng, LLM, và chiến lược phân mảnh</p>
        </div>
    </div>

    @* ===== A. KPI CARDS ===== *@
    <div class="bm-section-title"><i class="bi bi-activity"></i> Chỉ số chính (KPI)</div>
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-icon"><i class="bi bi-chat-dots-fill"></i></div>
            <div class="kpi-value">@Model.Dashboard.TotalQueries.ToString("N0")</div>
            <div class="kpi-label">Tổng số lượt thử nghiệm</div>
            <div class="kpi-sub">Tổng câu hỏi truy vấn đã được log trong hệ thống</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon"><i class="bi bi-lightning-charge-fill"></i></div>
            <div class="kpi-value">@Model.Dashboard.AvgRetrievalTimeMs.ToString("F0")<small style="font-size:.6em;font-weight:400"> ms</small></div>
            <div class="kpi-label">Thời gian truy xuất TB (Retrieval)</div>
            <div class="kpi-sub">TB tất cả mô hình nhúng · LLM gen: @Model.Dashboard.AvgGenerationTimeMs.ToString("F0") ms</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon"><i class="bi bi-hand-thumbs-up-fill"></i></div>
            <div class="kpi-value">@Model.Dashboard.HelpfulnessRate.ToString("F1")<small style="font-size:.6em;font-weight:400">%</small></div>
            <div class="kpi-label">Tỷ lệ hữu ích (Helpfulness Rate)</div>
            <div class="kpi-sub">Tỷ lệ Thumbs Up trung bình tất cả tổ hợp model</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon"><i class="bi bi-box-seam-fill"></i></div>
            <div class="kpi-value">@Model.Dashboard.AvgChunksPerDocument.ToString("F1")</div>
            <div class="kpi-label">Chunk trung bình / Tài liệu</div>
            <div class="kpi-sub">Kích thước TB mỗi chunk: @Model.Dashboard.AvgChunkSizeChars.ToString("F0") ký tự</div>
        </div>
    </div>

    @* ===== B. CHARTS ===== *@
    <div class="bm-section-title"><i class="bi bi-bar-chart-line-fill"></i> Biểu đồ so sánh trực quan</div>
    <div class="chart-grid">

        @* 1. Embedding Latency *@
        <div class="chart-card">
            <h5>So sánh tốc độ truy xuất <span class="sim-badge"><i class="bi bi-info-circle"></i> Simulated</span></h5>
            <div class="chart-desc">Thời gian truy vấn (ms) theo mô hình nhúng — Mô hình nào nhanh nhất?</div>
            <div class="chart-wrapper"><canvas id="chartEmbeddingLatency"></canvas></div>
        </div>

        @* 2. LLM Generation Latency *@
        <div class="chart-card">
            <h5>So sánh thời gian sinh LLM <span class="sim-badge"><i class="bi bi-info-circle"></i> Simulated</span></h5>
            <div class="chart-desc">Thời gian phản hồi (ms) theo mô hình LLM</div>
            <div class="chart-wrapper"><canvas id="chartLlmLatency"></canvas></div>
        </div>

        @* 3. Satisfaction Rate *@
        <div class="chart-card">
            <h5>Tỷ lệ hài lòng theo tổ hợp Model <span class="sim-badge"><i class="bi bi-info-circle"></i> Simulated</span></h5>
            <div class="chart-desc">% Thumbs Up / Down của từng tổ hợp Embedding + LLM</div>
            <div class="chart-wrapper"><canvas id="chartSatisfaction"></canvas></div>
        </div>

        @* 4. Chunking Strategy: Avg Chunk Count *@
        <div class="chart-card">
            <h5>Số lượng Chunk trung bình theo Chiến lược</h5>
            <div class="chart-desc">So sánh số chunk trung bình sinh ra trên mỗi tài liệu</div>
            <div class="chart-wrapper"><canvas id="chartChunkCount"></canvas></div>
        </div>

        @* 5. Chunking Strategy: Avg Chunk Size *@
        <div class="chart-card full-width">
            <h5>Kích thước Chunk trung bình theo Chiến lược</h5>
            <div class="chart-desc">Đánh giá mức độ đồng đều và độ lớn của mảnh giữa các chiến lược (ký tự)</div>
            <div class="chart-wrapper" style="max-height:340px"><canvas id="chartChunkSize"></canvas></div>
        </div>
    </div>

    @* ===== C. PLAYGROUND ===== *@
    <div class="bm-section-title"><i class="bi bi-terminal-fill"></i> Thực Nghiệm Trực Tiếp (Playground)</div>
    <div class="playground-card">
        <div class="pg-input-group">
            <div class="form-group" style="flex:2">
                <label>Câu hỏi thử nghiệm</label>
                <input type="text" id="pgQuestion" placeholder="Nhập câu hỏi để so sánh kết quả truy xuất giữa các mô hình..." />
            </div>
            <div class="form-group">
                <label>Môn học</label>
                <select id="pgSubject">
                    <option value="">— Tất cả môn —</option>
                    @foreach (var s in Model.Subjects)
                    {
                        <option value="@s.Value">@s.Text</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Chương</label>
                <select id="pgChapter">
                    <option value="">— Tất cả chương —</option>
                </select>
            </div>
            <button class="btn-benchmark" id="btnRunPlayground" onclick="runPlayground()">
                <i class="bi bi-play-fill"></i> Chạy thử nghiệm
            </button>
        </div>

        <div id="pgResults">
            <div class="pg-empty">
                <i class="bi bi-cpu"></i>
                Nhập câu hỏi và nhấn <strong>"Chạy thử nghiệm"</strong> để so sánh kết quả truy xuất side-by-side giữa các mô hình nhúng.
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        // ================================================================
        // CHART.JS CONFIGURATION
        // ================================================================
        Chart.defaults.color = '#94a3b8';
        Chart.defaults.font.family = "'Inter', sans-serif";
        Chart.defaults.font.size = 12;
        Chart.defaults.plugins.legend.labels.usePointStyle = true;
        Chart.defaults.plugins.legend.labels.pointStyleWidth = 10;

        const COLORS = {
            accent: '#6c5ce7', accent2: '#00cec9', accent3: '#fd79a8',
            accent4: '#fdcb6e', success: '#00b894', blue: '#0984e3',
            orange: '#e17055', purple: '#a29bfe'
        };

        // ── 1. Embedding Latency (Grouped Bar) ──
        const embLabels = @Html.Raw(Json.Serialize(Model.Dashboard.EmbeddingLatencies.Select(e => e.ModelName)));
        const embAvg = @Html.Raw(Json.Serialize(Model.Dashboard.EmbeddingLatencies.Select(e => e.AvgLatencyMs)));
        const embMin = @Html.Raw(Json.Serialize(Model.Dashboard.EmbeddingLatencies.Select(e => e.MinLatencyMs)));
        const embMax = @Html.Raw(Json.Serialize(Model.Dashboard.EmbeddingLatencies.Select(e => e.MaxLatencyMs)));

        new Chart(document.getElementById('chartEmbeddingLatency'), {
            type: 'bar',
            data: {
                labels: embLabels,
                datasets: [
                    {
                        label: 'TB (ms)', data: embAvg,
                        backgroundColor: 'rgba(108,92,231,0.7)', borderColor: COLORS.accent, borderWidth: 1, borderRadius: 6
                    },
                    {
                        label: 'Min (ms)', data: embMin,
                        backgroundColor: 'rgba(0,206,201,0.5)', borderColor: COLORS.accent2, borderWidth: 1, borderRadius: 6
                    },
                    {
                        label: 'Max (ms)', data: embMax,
                        backgroundColor: 'rgba(253,121,168,0.5)', borderColor: COLORS.accent3, borderWidth: 1, borderRadius: 6
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'top' } },
                scales: {
                    y: { beginAtZero: true, title: { display: true, text: 'Thời gian (ms)' }, grid: { color: 'rgba(255,255,255,.05)' } },
                    x: { grid: { display: false } }
                }
            }
        });

        // ── 2. LLM Generation Latency (Grouped Bar) ──
        const llmLabels = @Html.Raw(Json.Serialize(Model.Dashboard.LlmLatencies.Select(l => l.ModelName)));
        const llmAvg = @Html.Raw(Json.Serialize(Model.Dashboard.LlmLatencies.Select(l => l.AvgLatencyMs)));
        const llmMin = @Html.Raw(Json.Serialize(Model.Dashboard.LlmLatencies.Select(l => l.MinLatencyMs)));
        const llmMax = @Html.Raw(Json.Serialize(Model.Dashboard.LlmLatencies.Select(l => l.MaxLatencyMs)));

        new Chart(document.getElementById('chartLlmLatency'), {
            type: 'bar',
            data: {
                labels: llmLabels,
                datasets: [
                    {
                        label: 'TB (ms)', data: llmAvg,
                        backgroundColor: 'rgba(0,206,201,0.7)', borderColor: COLORS.accent2, borderWidth: 1, borderRadius: 6
                    },
                    {
                        label: 'Min (ms)', data: llmMin,
                        backgroundColor: 'rgba(253,203,110,0.5)', borderColor: COLORS.accent4, borderWidth: 1, borderRadius: 6
                    },
                    {
                        label: 'Max (ms)', data: llmMax,
                        backgroundColor: 'rgba(225,112,85,0.5)', borderColor: COLORS.orange, borderWidth: 1, borderRadius: 6
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'top' } },
                scales: {
                    y: { beginAtZero: true, title: { display: true, text: 'Thời gian (ms)' }, grid: { color: 'rgba(255,255,255,.05)' } },
                    x: { grid: { display: false } }
                }
            }
        });

        // ── 3. Satisfaction Rate (Stacked Horizontal Bar) ──
        const satLabels = @Html.Raw(Json.Serialize(Model.Dashboard.SatisfactionRates.Select(s => s.Label)));
        const satUp = @Html.Raw(Json.Serialize(Model.Dashboard.SatisfactionRates.Select(s => s.ThumbsUpPercent)));
        const satDown = @Html.Raw(Json.Serialize(Model.Dashboard.SatisfactionRates.Select(s => s.ThumbsDownPercent)));

        new Chart(document.getElementById('chartSatisfaction'), {
            type: 'bar',
            data: {
                labels: satLabels,
                datasets: [
                    {
                        label: '👍 Tốt (%)', data: satUp,
                        backgroundColor: 'rgba(0,184,148,0.7)', borderColor: COLORS.success, borderWidth: 1, borderRadius: 4
                    },
                    {
                        label: '👎 Không tốt (%)', data: satDown,
                        backgroundColor: 'rgba(225,112,85,0.7)', borderColor: COLORS.orange, borderWidth: 1, borderRadius: 4
                    }
                ]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                plugins: { legend: { position: 'top' } },
                scales: {
                    x: { stacked: true, max: 100, title: { display: true, text: 'Phần trăm (%)' }, grid: { color: 'rgba(255,255,255,.05)' } },
                    y: { stacked: true, grid: { display: false } }
                }
            }
        });

        // ── 4. Avg Chunk Count (Grouped Bar) ──
        const chunkStratLabels = @Html.Raw(Json.Serialize(Model.Dashboard.ChunkingBenchmarks.Select(c => c.Strategy)));
        const chunkCounts = @Html.Raw(Json.Serialize(Model.Dashboard.ChunkingBenchmarks.Select(c => c.AvgChunkCount)));
        const chunkDocCounts = @Html.Raw(Json.Serialize(Model.Dashboard.ChunkingBenchmarks.Select(c => c.TotalDocuments)));

        new Chart(document.getElementById('chartChunkCount'), {
            type: 'bar',
            data: {
                labels: chunkStratLabels,
                datasets: [{
                    label: 'Chunk TB / tài liệu',
                    data: chunkCounts,
                    backgroundColor: [
                        'rgba(108,92,231,0.7)',
                        'rgba(0,206,201,0.7)',
                        'rgba(253,203,110,0.7)'
                    ],
                    borderColor: [COLORS.accent, COLORS.accent2, COLORS.accent4],
                    borderWidth: 1,
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            afterLabel: function(ctx) {
                                return `Tài liệu: ${chunkDocCounts[ctx.dataIndex]}`;
                            }
                        }
                    }
                },
                scales: {
                    y: { beginAtZero: true, title: { display: true, text: 'Số chunk trung bình' }, grid: { color: 'rgba(255,255,255,.05)' } },
                    x: { grid: { display: false } }
                }
            }
        });

        // ── 5. Avg Chunk Size (Grouped Bar) ──
        const chunkSizes = @Html.Raw(Json.Serialize(Model.Dashboard.ChunkingBenchmarks.Select(c => c.AvgChunkSize)));

        new Chart(document.getElementById('chartChunkSize'), {
            type: 'bar',
            data: {
                labels: chunkStratLabels,
                datasets: [{
                    label: 'Kích thước TB (ký tự)',
                    data: chunkSizes,
                    backgroundColor: [
                        'rgba(253,121,168,0.7)',
                        'rgba(162,155,254,0.7)',
                        'rgba(0,184,148,0.7)'
                    ],
                    borderColor: [COLORS.accent3, COLORS.purple, COLORS.success],
                    borderWidth: 1,
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, title: { display: true, text: 'Ký tự / chunk' }, grid: { color: 'rgba(255,255,255,.05)' } },
                    x: { grid: { display: false } }
                }
            }
        });

        // ================================================================
        // PLAYGROUND
        // ================================================================

        // Subject → Chapter cascade
        document.getElementById('pgSubject').addEventListener('change', async function () {
            const chapterSelect = document.getElementById('pgChapter');
            chapterSelect.innerHTML = '<option value="">— Tất cả chương —</option>';

            const subId = this.value;
            if (!subId) return;

            try {
                const resp = await fetch(`?handler=ChaptersBySubject&subjectId=${subId}`);
                const chapters = await resp.json();
                chapters.forEach(ch => {
                    const opt = document.createElement('option');
                    opt.value = ch.value;
                    opt.textContent = ch.text;
                    chapterSelect.appendChild(opt);
                });
            } catch (e) {
                console.error('Error loading chapters:', e);
            }
        });

        async function runPlayground() {
            const question = document.getElementById('pgQuestion').value.trim();
            if (!question) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({ icon: 'warning', title: 'Chưa nhập câu hỏi', text: 'Vui lòng nhập câu hỏi để thử nghiệm.', timer: 2500 });
                }
                return;
            }

            const btn = document.getElementById('btnRunPlayground');
            const resultsDiv = document.getElementById('pgResults');

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang chạy...';
            resultsDiv.innerHTML = '<div class="pg-empty"><div class="spinner-border text-info" role="status"></div><br/>Đang chạy benchmark trên tất cả mô hình nhúng...</div>';

            const subjectId = document.getElementById('pgSubject').value || null;
            const chapterId = document.getElementById('pgChapter').value || null;

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const resp = await fetch('?handler=RunPlayground', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token || ''
                    },
                    body: JSON.stringify({ question, subjectId: subjectId ? parseInt(subjectId) : null, chapterId: chapterId ? parseInt(chapterId) : null })
                });

                const result = await resp.json();

                if (result.success && result.data && result.data.length > 0) {
                    renderPlaygroundResults(result.data);
                } else {
                    resultsDiv.innerHTML = `<div class="pg-empty"><i class="bi bi-exclamation-triangle"></i>${result.message || 'Không có kết quả.'}</div>`;
                }
            } catch (e) {
                console.error('Playground error:', e);
                resultsDiv.innerHTML = '<div class="pg-empty"><i class="bi bi-exclamation-triangle"></i>Đã xảy ra lỗi khi chạy thử nghiệm.</div>';
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-play-fill"></i> Chạy thử nghiệm';
            }
        }

        function renderPlaygroundResults(data) {
            const container = document.getElementById('pgResults');
            let html = '<div class="pg-results-grid">';

            data.forEach((model, idx) => {
                html += `
                    <div class="pg-model-card">
                        <div class="model-name">
                            <span class="dot"></span>
                            ${escapeHtml(model.modelName)}
                        </div>
                        <div class="pg-timing">
                            <span class="badge-timing">⚡ Embed: ${model.embeddingTimeMs.toFixed(2)} ms</span>
                            <span class="badge-timing search">🔍 Search: ${model.searchTimeMs.toFixed(2)} ms</span>
                            <span class="badge-timing total">Σ ${model.totalTimeMs.toFixed(2)} ms</span>
                        </div>`;

                if (model.topChunks && model.topChunks.length > 0) {
                    model.topChunks.forEach((chunk, ci) => {
                        const scoreColor = chunk.cosineScore >= 0.5 ? '#00b894' : chunk.cosineScore >= 0.2 ? '#fdcb6e' : '#e17055';
                        html += `
                            <div class="pg-chunk-item">
                                <div class="chunk-header">
                                    <span class="chunk-title">📄 ${escapeHtml(chunk.documentTitle)} ${chunk.pageNumber ? '(Tr. ' + chunk.pageNumber + ')' : ''}</span>
                                    <span class="cosine-badge" style="color:${scoreColor}; background:${scoreColor}22">
                                        Cosine: ${chunk.cosineScore.toFixed(4)}
                                    </span>
                                </div>
                                <div class="chunk-text">${escapeHtml(chunk.contentSnippet)}</div>
                            </div>`;
                    });
                } else {
                    html += '<div style="color:var(--bm-muted);font-size:.82rem;padding:8px 0;">Không tìm thấy chunk phù hợp.</div>';
                }

                html += '</div>';
            });

            html += '</div>';
            container.innerHTML = html;
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.appendChild(document.createTextNode(text));
            return div.innerHTML;
        }

        // Allow Enter key to trigger playground
        document.getElementById('pgQuestion')?.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                runPlayground();
            }
        });
    </script>
    @Html.AntiForgeryToken()
}
