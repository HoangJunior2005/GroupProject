@page
@model LearningDocumentSystem.Web.Pages.Admin.BenchmarksModel
@using System.Text.Json
@{
    ViewData["Title"] = "Benchmark";
    var providerLabels = JsonSerializer.Serialize(Model.Dashboard.Providers.Select(x => x.ProviderName));
    var latencyData = JsonSerializer.Serialize(Model.Dashboard.Providers.Select(x => Math.Round(x.AverageLatencyMs, 1)));
    var helpfulnessData = JsonSerializer.Serialize(Model.Dashboard.Providers.Select(x => Math.Round(x.HelpfulnessRate, 1)));
}

<style>
    .benchmark-header { display:flex; align-items:flex-start; justify-content:space-between; gap:1rem; margin-bottom:1.25rem; }
    .benchmark-header h1 { font-size:1.55rem; font-weight:700; margin:0 0 .25rem; }
    .benchmark-header p { color:#64748b; margin:0; }
    .metric-grid { display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:1rem; margin-bottom:1rem; }
    .metric { background:#fff; border:1px solid #e2e8f0; border-radius:8px; padding:1rem; min-width:0; }
    .metric-label { color:#64748b; font-size:.78rem; font-weight:600; text-transform:uppercase; }
    .metric-value { color:#172033; font-size:1.65rem; font-weight:700; margin-top:.35rem; }
    .metric-note { color:#64748b; font-size:.78rem; margin-top:.2rem; }
    .benchmark-grid { display:grid; grid-template-columns:minmax(0,1.3fr) minmax(300px,.7fr); gap:1rem; margin-bottom:1rem; }
    .panel { background:#fff; border:1px solid #e2e8f0; border-radius:8px; padding:1rem; min-width:0; }
    .panel-title { font-size:1rem; font-weight:700; margin:0 0 .85rem; }
    .chart-wrap { position:relative; height:280px; }
    .result-item { border-top:1px solid #e2e8f0; padding:.9rem 0; }
    .result-item:first-child { border-top:0; }
    .result-meta { display:flex; gap:.65rem; flex-wrap:wrap; color:#64748b; font-size:.8rem; }
    .result-score { color:#0f766e; font-weight:700; }
    .result-content { color:#334155; margin:.45rem 0 0; white-space:pre-line; }
    .empty-state { color:#64748b; text-align:center; padding:2rem 1rem; }
    @@media (max-width: 1100px) { .metric-grid { grid-template-columns:repeat(2,minmax(0,1fr)); } .benchmark-grid { grid-template-columns:1fr; } }
    @@media (max-width: 600px) { .metric-grid { grid-template-columns:1fr; } .benchmark-header { display:block; } }
</style>

<div class="benchmark-header">
    <div>
        <h1>Benchmark Dashboard</h1>
        <p>Đánh giá hiệu năng LLM, mức độ hữu ích và chất lượng truy xuất tài liệu.</p>
    </div>
    <span class="badge text-bg-light border"><i class="bi bi-database-check me-1"></i>Dữ liệu thực tế</span>
</div>

<div class="metric-grid">
    <div class="metric"><div class="metric-label">Câu hỏi đã đo</div><div class="metric-value">@Model.Dashboard.TotalQuestions.ToString("N0")</div><div class="metric-note">Câu trả lời có thông tin provider</div></div>
    <div class="metric"><div class="metric-label">Latency trung bình</div><div class="metric-value">@Model.Dashboard.AverageLatencyMs.ToString("N0") ms</div><div class="metric-note">Thời gian phản hồi của LLM</div></div>
    <div class="metric"><div class="metric-label">Tỷ lệ hữu ích</div><div class="metric-value">@Model.Dashboard.HelpfulnessRate.ToString("N1")%</div><div class="metric-note">@Model.Dashboard.RatedResponses phản hồi đã đánh giá</div></div>
    <div class="metric"><div class="metric-label">Token đã dùng</div><div class="metric-value">@Model.Dashboard.TotalTokens.ToString("N0")</div><div class="metric-note">Prompt và completion token</div></div>
</div>

<div class="benchmark-grid">
    <section class="panel">
        <h2 class="panel-title">So sánh độ trễ LLM</h2>
        <div class="chart-wrap"><canvas id="latencyChart"></canvas></div>
    </section>
    <section class="panel">
        <h2 class="panel-title">Mức độ hữu ích theo provider</h2>
        <div class="chart-wrap"><canvas id="helpfulnessChart"></canvas></div>
    </section>
</div>

<div class="metric-grid">
    <div class="metric"><div class="metric-label">Tài liệu đã chunk</div><div class="metric-value">@Model.Dashboard.TotalDocuments.ToString("N0")</div></div>
    <div class="metric"><div class="metric-label">Tổng số chunk</div><div class="metric-value">@Model.Dashboard.TotalChunks.ToString("N0")</div></div>
    <div class="metric"><div class="metric-label">Chunk / tài liệu</div><div class="metric-value">@Model.Dashboard.AverageChunksPerDocument.ToString("N1")</div></div>
    <div class="metric"><div class="metric-label">Ký tự / chunk</div><div class="metric-value">@Model.Dashboard.AverageChunkLength.ToString("N0")</div></div>
</div>

<div class="benchmark-grid">
    <section class="panel">
        <h2 class="panel-title">Retrieval playground</h2>
        <form id="retrievalForm" method="post" asp-page-handler="RunRetrieval">
            <div class="mb-3">
                <label class="form-label fw-semibold" for="question">Câu hỏi thử nghiệm</label>
                <textarea class="form-control" id="question" name="question" rows="3" maxlength="1000" required placeholder="Nhập câu hỏi cần kiểm tra retrieval..."></textarea>
            </div>
            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <label class="form-label" for="subjectId">Môn học</label>
                    <select class="form-select" id="subjectId" name="subjectId">
                        <option value="">Tất cả môn học</option>
                        @foreach (var subject in Model.Subjects) { <option value="@subject.SubjectID">@subject.SubjectCode - @subject.SubjectName</option> }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="chapterId">Chương</label>
                    <select class="form-select" id="chapterId" name="chapterId">
                        <option value="">Tất cả chương</option>
                        @foreach (var chapter in Model.Chapters) { <option value="@chapter.ChapterID" data-subject="@chapter.SubjectID">@chapter.SubjectName - Chương @chapter.ChapterNumber</option> }
                    </select>
                </div>
            </div>
            <button class="btn btn-primary" type="submit" id="runButton"><i class="bi bi-play-fill me-1"></i>Chạy thử nghiệm</button>
        </form>
        <div id="retrievalResults" class="mt-3"><div class="empty-state">Kết quả top 5 chunk sẽ hiển thị tại đây.</div></div>
    </section>

    <section class="panel">
        <h2 class="panel-title">Chi tiết provider</h2>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead><tr><th>Provider</th><th class="text-end">Lượt</th><th class="text-end">Latency</th><th class="text-end">Hữu ích</th></tr></thead>
                <tbody>
                @if (Model.Dashboard.Providers.Count == 0) { <tr><td colspan="4" class="text-center text-muted py-4">Chưa có dữ liệu benchmark.</td></tr> }
                @foreach (var item in Model.Dashboard.Providers)
                {
                    <tr><td><strong>@item.ProviderName</strong><div class="small text-muted">@item.ModelName</div></td><td class="text-end">@item.RequestCount</td><td class="text-end">@item.AverageLatencyMs.ToString("N0") ms</td><td class="text-end">@item.HelpfulnessRate.ToString("N1")%</td></tr>
                }
                </tbody>
            </table>
        </div>
    </section>
</div>

<section class="panel">
    <h2 class="panel-title">Kết quả gần nhất</h2>
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead><tr><th>Thời gian</th><th>Provider / Model</th><th class="text-end">Latency</th><th class="text-end">Token</th><th class="text-center">Đánh giá</th></tr></thead>
            <tbody>
            @if (Model.Dashboard.RecentResponses.Count == 0) { <tr><td colspan="5" class="text-center text-muted py-4">Chưa có lần gọi LLM nào được ghi nhận.</td></tr> }
            @foreach (var item in Model.Dashboard.RecentResponses)
            {
                <tr><td>@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td><td><strong>@item.ProviderName</strong><div class="small text-muted">@item.ModelName</div></td><td class="text-end">@((item.ExecutionTimeMs ?? 0).ToString("N0")) ms</td><td class="text-end">@item.TotalTokens.ToString("N0")</td><td class="text-center">@(item.Feedback == 1 ? "Hữu ích" : item.Feedback == -1 ? "Chưa hữu ích" : "-")</td></tr>
            }
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
    const labels = @Html.Raw(providerLabels);
    const chartOptions = { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#e2e8f0' } }, x: { grid: { display: false } } } };
    new Chart(document.getElementById('latencyChart'), { type: 'bar', data: { labels, datasets: [{ data: @Html.Raw(latencyData), backgroundColor: '#2563eb', borderRadius: 4 }] }, options: chartOptions });
    new Chart(document.getElementById('helpfulnessChart'), { type: 'bar', data: { labels, datasets: [{ data: @Html.Raw(helpfulnessData), backgroundColor: '#0f766e', borderRadius: 4 }] }, options: { ...chartOptions, scales: { ...chartOptions.scales, y: { ...chartOptions.scales.y, max: 100 } } } });

    const subjectSelect = document.getElementById('subjectId');
    const chapterSelect = document.getElementById('chapterId');
    const chapterOptions = [...chapterSelect.options];
    subjectSelect.addEventListener('change', () => {
        const selected = subjectSelect.value;
        chapterSelect.value = '';
        chapterOptions.forEach((option, index) => option.hidden = index > 0 && selected && option.dataset.subject !== selected);
    });

    document.getElementById('retrievalForm').addEventListener('submit', async event => {
        event.preventDefault();
        const form = event.currentTarget;
        const button = document.getElementById('runButton');
        const results = document.getElementById('retrievalResults');
        button.disabled = true;
        button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Đang đo...';
        try {
            const response = await fetch(form.action, { method: 'POST', body: new FormData(form), headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            const data = await response.json();
            if (!response.ok) throw new Error(data.message || 'Không thể chạy thử nghiệm.');
            const header = `<div class="small text-muted mb-2">Quét ${data.scannedChunks.toLocaleString()} chunk trong <strong>${data.executionTimeMs.toFixed(1)} ms</strong></div>`;
            results.innerHTML = header + (data.results.length ? data.results.map(item => `<article class="result-item"><div class="result-meta"><strong>${escapeHtml(item.documentTitle)}</strong><span>${escapeHtml(item.chapterName)}</span><span>Trang ${item.pageNumber ?? 'N/A'}</span><span class="result-score">${item.similarityScore.toFixed(1)}%</span></div><p class="result-content">${escapeHtml(item.contentSnippet)}</p></article>`).join('') : '<div class="empty-state">Không tìm thấy chunk phù hợp.</div>');
        } catch (error) {
            results.innerHTML = `<div class="alert alert-danger mb-0">${escapeHtml(error.message)}</div>`;
        } finally {
            button.disabled = false;
            button.innerHTML = '<i class="bi bi-play-fill me-1"></i>Chạy thử nghiệm';
        }
    });
    function escapeHtml(value) { const node = document.createElement('div'); node.textContent = value ?? ''; return node.innerHTML; }
</script>
}
