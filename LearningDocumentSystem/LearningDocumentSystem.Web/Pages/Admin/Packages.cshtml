@page
@model LearningDocumentSystem.Web.Pages.Admin.PackagesModel
@{
    ViewData["Title"] = "Quan ly goi";
}

<style>
    .admin-package-grid { display:grid; grid-template-columns:minmax(0,1.35fr) minmax(320px,.65fr); gap:1rem; align-items:start; }
    .admin-panel { background:#fff; border:1px solid #dbe3ed; border-radius:8px; }
    .admin-panel-header { padding:1rem 1.1rem; border-bottom:1px solid #e5e7eb; display:flex; justify-content:space-between; align-items:center; gap:1rem; }
    .admin-panel-body { padding:1.1rem; }
    .status-dot-plan { width:8px; height:8px; border-radius:50%; display:inline-block; margin-right:.4rem; }
    @@media (max-width:1050px) { .admin-package-grid { grid-template-columns:1fr; } }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-box-seam-fill me-2"></i>Quản lý gói dịch vụ</h1>
        <p class="page-subtitle">Cấu hình giá, hạn mức và mô hình AI cho Free, Plus, Pro.</p>
    </div>
</div>

<div class="admin-package-grid">
    <section class="admin-panel">
        <div class="admin-panel-header"><strong>Danh sách gói</strong><span class="text-muted small">@Model.Plans.Count gói có sẵn</span></div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead><tr><th>Gói</th><th>Giá</th><th>Hạn mức</th><th>Models</th><th>Trạng thái</th><th class="text-end">Thao tác</th></tr></thead>
                <tbody>
                @foreach (var plan in Model.Plans)
                {
                    <tr>
                        <td><strong>@plan.Name</strong><div class="small text-muted">@plan.Code</div></td>
                        <td>@plan.Price.ToString("N0") ₫</td>
                        <td>@(plan.DailyMessageLimit?.ToString() ?? "Không giới hạn")</td>
                        <td><span class="small">@string.Join(", ", plan.AllowedProviders)</span></td>
                        <td><span><i class="status-dot-plan" style="background:@(plan.IsActive ? "#16a34a" : "#94a3b8")"></i>@(plan.IsActive ? "Đang bật" : "Tạm dừng")</span></td>
                        <td class="text-end text-nowrap">
                            <a asp-page="./Packages" asp-route-editCode="@plan.Code" class="btn btn-sm btn-outline-primary" title="Sửa cấu hình"><i class="bi bi-pencil-square me-1"></i>Sửa</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>

    <section class="admin-panel">
        @if (Model.IsEditing)
        {
            <div class="admin-panel-header"><strong>Cập nhật cấu hình gói: <span class="text-primary">@Model.Code</span></strong></div>
            <div class="admin-panel-body">
                <form method="post" asp-page-handler="Save">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <input type="hidden" asp-for="OriginalCode" />
                    <input type="hidden" asp-for="Code" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold" asp-for="Name">Tên hiển thị</label>
                        <input class="form-control" asp-for="Name" required maxlength="50" />
                    </div>
                    
                    @if (Model.Code == "Free")
                    {
                        <input type="hidden" asp-for="Price" value="0" />
                        <input type="hidden" asp-for="IsActive" value="true" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Giá (VND)</label>
                            <input class="form-control" value="0 ₫" disabled />
                            <div class="form-text small text-muted">Gói Free mặc định luôn có giá là 0 ₫.</div>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold" asp-for="Price">Giá (VND)</label>
                            <input class="form-control" asp-for="Price" type="number" min="0" step="1000" required />
                        </div>
                    }
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold" asp-for="DailyMessageLimit">Hạn mức câu hỏi/ngày</label>
                        <input class="form-control" asp-for="DailyMessageLimit" type="number" min="0" placeholder="Trống (Không giới hạn)" />
                        <div class="form-text small text-muted">Để trống hoặc nhập 0 để cấu hình không giới hạn.</div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mô hình AI cho phép sử dụng</label>
                        @foreach (var provider in new[] { "Gemini", "Groq", "OpenAI" })
                        {
                            <div class="form-check">
                                @if (Model.Providers.Contains(provider))
                                {
                                    <input class="form-check-input" type="checkbox" name="Providers" value="@provider" id="provider-@provider" checked>
                                }
                                else
                                {
                                    <input class="form-check-input" type="checkbox" name="Providers" value="@provider" id="provider-@provider">
                                }
                                <label class="form-check-label" for="provider-@provider">@provider</label>
                            </div>
                        }
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold" asp-for="Features">Danh sách tính năng (mỗi dòng một mục)</label>
                        <textarea class="form-control" asp-for="Features" rows="5"></textarea>
                    </div>
                    
                    @if (Model.Code != "Free")
                    {
                        <div class="form-check form-switch mb-4">
                            <input class="form-check-input" asp-for="IsActive">
                            <label class="form-check-label" asp-for="IsActive">Cho phép người dùng đăng ký gói này</label>
                        </div>
                    }
                    
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary flex-fill" type="submit"><i class="bi bi-save me-1"></i>Lưu thay đổi</button>
                        <a asp-page="./Packages" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        }
        else
        {
            <div class="admin-panel-header"><strong>Thông tin cấu hình</strong></div>
            <div class="admin-panel-body py-5 text-center text-muted">
                <i class="bi bi-pencil-square fs-1 mb-3 text-secondary opacity-50 d-block"></i>
                <p class="mb-0">Chọn một gói dịch vụ từ danh sách bên trái để bắt đầu chỉnh sửa cấu hình.</p>
            </div>
        }
    </section>
</div>
